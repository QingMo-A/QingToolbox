<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
                    xmlns:converters="clr-namespace:QingToolbox.Shell.Converters">
    <converters:ModuleIconSourceConverter x:Key="ModuleIconSourceConverter"/>

    <SolidColorBrush x:Key="ShellBackgroundBrush" Color="#F5F7FB"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#F7FBFF"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="#EAF2FF"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#1D4ED8"/>
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#172033"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#64748B"/>
    <SolidColorBrush x:Key="StatusBackgroundBrush" Color="#E8EEF8"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="#DCE2EA"/>
    <LinearGradientBrush x:Key="ShellBackgroundGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F8FAFC" Offset="0"/>
        <GradientStop Color="#EEF5FF" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="GlassPanelBackgroundBrush" Color="#D9FFFFFF"/>
    <SolidColorBrush x:Key="GlassPanelBorderBrush" Color="#88FFFFFF"/>
    <SolidColorBrush x:Key="GlassPanelHighlightBrush" Color="#F2FFFFFF"/>
    <SolidColorBrush x:Key="PrimaryAccentBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="PrimaryAccentSoftBrush" Color="#E8F0FF"/>
    <SolidColorBrush x:Key="DangerSoftBrush" Color="#FFF1F0"/>
    <SolidColorBrush x:Key="SuccessSoftBrush" Color="#ECFDF3"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="#64748B"/>
    <SolidColorBrush x:Key="StrongTextBrush" Color="#172033"/>
    <SolidColorBrush x:Key="WindowTitleBarDividerBrush" Color="#D9E2EF"/>
    <CornerRadius x:Key="GlassPanelCornerRadius">24</CornerRadius>
    <CornerRadius x:Key="CardCornerRadius">18</CornerRadius>
    <CornerRadius x:Key="ButtonCornerRadius">12</CornerRadius>
    <CornerRadius x:Key="SidebarItemCornerRadius">14</CornerRadius>
    <Duration x:Key="FastAnimationDuration">0:0:0.12</Duration>
    <Duration x:Key="NormalAnimationDuration">0:0:0.18</Duration>
    <Duration x:Key="SlowAnimationDuration">0:0:0.26</Duration>
    <DropShadowEffect x:Key="SoftPanelShadow" BlurRadius="22" ShadowDepth="5"
                      Opacity="0.12" Color="#334155"/>
    <DropShadowEffect x:Key="FloatingPanelShadow" BlurRadius="32" ShadowDepth="8"
                      Opacity="0.16" Color="#334155"/>
    <DropShadowEffect x:Key="HoverCardShadow" BlurRadius="25" ShadowDepth="7"
                      Opacity="0.18" Color="#2563EB"/>

    <Style x:Key="WindowTitleBarStyle" TargetType="UserControl">
        <Setter Property="Background" Value="#F7FBFF"/>
        <Setter Property="Focusable" Value="False"/>
    </Style>

    <Style x:Key="WindowTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource StrongTextBrush}"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="WindowSubtitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        <Style.Triggers>
            <Trigger Property="Text" Value=""><Setter Property="Visibility" Value="Collapsed"/></Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="WindowCaptionButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="47"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource StrongTextBrush}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Focusable" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Background" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Background" Property="Background" Value="{StaticResource SidebarHoverBrush}"/></Trigger>
                        <Trigger Property="IsPressed" Value="True"><Setter TargetName="Background" Property="Background" Value="#D8E7FF"/></Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True"><Setter TargetName="Background" Property="BorderBrush" Value="{StaticResource AccentBrush}"/><Setter TargetName="Background" Property="BorderThickness" Value="1"/></Trigger>
                        <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.4"/></Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="WindowCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource WindowCaptionButtonStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Background" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Background" Property="Background" Value="#E81123"/><Setter Property="Foreground" Value="White"/></Trigger>
                        <Trigger Property="IsPressed" Value="True"><Setter TargetName="Background" Property="Background" Value="#C50F1F"/><Setter Property="Foreground" Value="White"/></Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True"><Setter TargetName="Background" Property="BorderBrush" Value="{StaticResource AccentBrush}"/><Setter TargetName="Background" Property="BorderThickness" Value="1"/></Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="WindowSystemMenuButtonStyle" TargetType="Button" BasedOn="{StaticResource WindowCaptionButtonStyle}">
        <Setter Property="Width" Value="44"/>
    </Style>

    <Style x:Key="WindowTitleBarDividerStyle" TargetType="Border">
        <Setter Property="BorderBrush" Value="{StaticResource WindowTitleBarDividerBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>

    <Style x:Key="LiquidGlassPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource GlassPanelBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource GlassPanelBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource GlassPanelCornerRadius}"/>
    </Style>

    <Style x:Key="PageTransitionStyle" TargetType="Grid">
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
        <Setter Property="RenderTransform">
            <Setter.Value><TranslateTransform Y="0"/></Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsVisible" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0" To="1" Duration="0:0:0.18"
                                             FillBehavior="Stop"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                             From="8" To="0" Duration="0:0:0.18"
                                             FillBehavior="Stop">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ShellSvgIconStyle" TargetType="{x:Type svgc:SvgViewbox}">
        <Setter Property="Width" Value="21"/>
        <Setter Property="Height" Value="21"/>
        <Setter Property="Stretch" Value="Uniform"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="FluentIconStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe Fluent Icons"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="Foreground" Value="#52637A"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="CompactFluentIconStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource FluentIconStyle}">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
        <Setter Property="Margin" Value="0,0,6,0"/>
    </Style>

    <Style x:Key="DefaultModuleFluentIconStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource FluentIconStyle}">
        <Setter Property="FontSize" Value="25"/>
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Text" Value="&#xE71D;"/>
    </Style>

    <Style x:Key="SidebarIconContainerStyle" TargetType="Border">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style x:Key="CompactSvgIconStyle"
           TargetType="{x:Type svgc:SvgViewbox}"
           BasedOn="{StaticResource ShellSvgIconStyle}">
        <Setter Property="Width" Value="16"/>
        <Setter Property="Height" Value="16"/>
    </Style>

    <Style x:Key="ModuleIconContainerStyle" TargetType="Border">
        <Setter Property="Width" Value="42"/>
        <Setter Property="Height" Value="42"/>
        <Setter Property="Margin" Value="0,0,12,0"/>
        <Setter Property="Padding" Value="7"/>
        <Setter Property="Background" Value="#EFF6FF"/>
        <Setter Property="BorderBrush" Value="#BFDBFE"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
    </Style>

    <Style x:Key="ModuleIconStyle"
           TargetType="{x:Type svgc:SvgViewbox}"
           BasedOn="{StaticResource ShellSvgIconStyle}">
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
    </Style>

    <Style x:Key="RefreshButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="18,10"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform"><Setter.Value><TransformGroup>
            <ScaleTransform ScaleX="1" ScaleY="1"/><TranslateTransform Y="0"/>
        </TransformGroup></Setter.Value></Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="7">
                        <Grid>
                            <Border x:Name="HoverOverlay"
                                    Margin="-18,-10"
                                    Background="#24FFFFFF"
                                    CornerRadius="7"
                                    Opacity="0"
                                    IsHitTestVisible="False"/>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.18"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                         To="-1" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.18"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                         To="0" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="RenderTransform">
                                <Setter.Value><TransformGroup><ScaleTransform ScaleX="0.98" ScaleY="0.98"/><TranslateTransform Y="0"/></TransformGroup></Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder"
                                    Property="Opacity"
                                    Value="0.55"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SidebarButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="44"/>
        <Setter Property="Margin" Value="0,3"/>
        <Setter Property="Padding" Value="8,0"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Foreground" Value="#52637A"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="RenderTransform"><Setter.Value><TranslateTransform X="0"/></Setter.Value></Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="SelectionIndicator"
                                Width="3"
                                Height="22"
                                HorizontalAlignment="Left"
                                Background="{StaticResource AccentBrush}"
                                CornerRadius="2"
                                Opacity="0"/>
                        <Border x:Name="ButtonBorder"
                                Margin="5,0,0,0"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{StaticResource SidebarItemCornerRadius}">
                            <Grid>
                                <Border x:Name="HoverOverlay"
                                        Margin="-8,0"
                                        Background="#DCEBFF"
                                        CornerRadius="{StaticResource SidebarItemCornerRadius}"
                                        Opacity="0"
                                        IsHitTestVisible="False"/>
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="#1D4ED8"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                         To="2" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                         To="0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="Tag" Value="Selected">
                            <Setter TargetName="ButtonBorder"
                                    Property="Background"
                                    Value="#DCEBFF"/>
                            <Setter TargetName="SelectionIndicator"
                                    Property="Opacity"
                                    Value="1"/>
                            <Setter Property="Foreground" Value="#1D4ED8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SidebarLabelStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="12,0,0,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Opacity" Value="0"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="True">
                <DataTrigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             To="1"
                                             Duration="0:0:0.18"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             To="0"
                                             Duration="0:0:0.16"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.ExitActions>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ModuleCardStyle" TargetType="Border">
        <Setter Property="Margin" Value="0,0,10,12"/>
        <Setter Property="Padding" Value="18"/>
        <Setter Property="Background" Value="{StaticResource GlassPanelBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource GlassPanelBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}"/>
        <Setter Property="RenderTransform"><Setter.Value><TranslateTransform Y="0"/></Setter.Value></Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="RenderTransform"><Setter.Value><TranslateTransform Y="-2"/></Setter.Value></Setter>
                <Setter Property="BorderBrush" Value="#B8D3FF"/>
                <Setter Property="Background" Value="#F2FFFFFF"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ModuleCardCompactStyle" TargetType="Border"
           BasedOn="{StaticResource ModuleCardStyle}"/>

    <Style x:Key="ModuleDetailsExpanderStyle" TargetType="Expander">
        <Setter Property="Margin" Value="0,14,0,0"/>
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
    </Style>

    <Style x:Key="SummaryCardStyle" TargetType="Border">
        <Setter Property="Margin" Value="0,0,10,0"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="Height" Value="70"/>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FDFEFF" Offset="0"/>
                    <GradientStop Color="#E9F3FF" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="#CFE2FF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}"/>
    </Style>

    <Style x:Key="SummaryNumberStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="23"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
    </Style>

    <Style x:Key="SummaryLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
        <Setter Property="Margin" Value="0,2,0,0"/>
    </Style>

    <Style x:Key="StatusMessageStyle" TargetType="Border">
        <Setter Property="Padding" Value="14,9"/>
        <Setter Property="Background" Value="#EAF2FF"/>
        <Setter Property="BorderBrush" Value="#D5E5FF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
    </Style>

    <Style x:Key="InfoLabelStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Margin" Value="0,0,0,3"/>
    </Style>

    <Style x:Key="InfoValueStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="StateBadgeStyle" TargetType="Border">
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Background" Value="#DBEAFE"/>
        <Setter Property="CornerRadius" Value="12"/>
    </Style>

    <Style x:Key="ErrorPanelStyle" TargetType="Border">
        <Setter Property="Margin" Value="0,16,0,0"/>
        <Setter Property="Padding" Value="14,11"/>
        <Setter Property="Background" Value="#FFF3E8"/>
        <Setter Property="BorderBrush" Value="#FED7AA"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <Style x:Key="LifecycleButtonStyle" TargetType="Button">
        <Setter Property="MinWidth" Value="82"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
        <Setter Property="Padding" Value="14,0"/>
        <Setter Property="Foreground" Value="#1E3A8A"/>
        <Setter Property="Background" Value="#EFF6FF"/>
        <Setter Property="BorderBrush" Value="#BFDBFE"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform"><Setter.Value><TransformGroup>
            <ScaleTransform ScaleX="1" ScaleY="1"/><TranslateTransform Y="0"/>
        </TransformGroup></Setter.Value></Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource ButtonCornerRadius}">
                        <Grid>
                            <Border x:Name="HoverOverlay"
                                    Margin="-14,0"
                                    Background="#20FFFFFF"
                                    CornerRadius="{StaticResource ButtonCornerRadius}"
                                    Opacity="0"
                                    IsHitTestVisible="False"/>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.18"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                         To="-1" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.18"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                         To="0" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="RenderTransform"><Setter.Value><TransformGroup><ScaleTransform ScaleX="0.98" ScaleY="0.98"/><TranslateTransform Y="0"/></TransformGroup></Setter.Value></Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder"
                                    Property="Opacity"
                                    Value="0.45"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="LifecycleDangerButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource LifecycleButtonStyle}">
        <Setter Property="Foreground" Value="#9A3412"/>
        <Setter Property="Background" Value="#FFF7ED"/>
        <Setter Property="BorderBrush" Value="#FED7AA"/>
    </Style>

    <Style x:Key="PrimaryActionButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource LifecycleButtonStyle}">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
    </Style>

    <Style x:Key="SecondaryActionButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource LifecycleButtonStyle}">
        <Setter Property="Foreground" Value="#334155"/>
        <Setter Property="Background" Value="#F8FAFC"/>
        <Setter Property="BorderBrush" Value="#CBD5E1"/>
    </Style>

    <Style x:Key="DangerActionButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource LifecycleDangerButtonStyle}"/>

    <Style x:Key="RuntimeErrorPanelStyle"
           TargetType="Border"
           BasedOn="{StaticResource ErrorPanelStyle}">
        <Setter Property="Background" Value="#FEF2F2"/>
        <Setter Property="BorderBrush" Value="#FECACA"/>
    </Style>

    <Style x:Key="ModuleViewHostStyle" TargetType="Border">
        <Setter Property="Margin" Value="18,0,0,0"/>
        <Setter Property="Background" Value="{StaticResource GlassPanelBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource GlassPanelBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource GlassPanelCornerRadius}"/>
    </Style>

    <Style x:Key="WorkspacePanelStyle" TargetType="Border"
           BasedOn="{StaticResource ModuleViewHostStyle}"/>

    <Style x:Key="WorkspaceEmptyStateStyle" TargetType="StackPanel">
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="MaxWidth" Value="360"/>
    </Style>

    <Style x:Key="EmptyStateCardStyle"
           TargetType="Border"
           BasedOn="{StaticResource LiquidGlassPanelStyle}">
        <Setter Property="Padding" Value="28"/>
        <Setter Property="BorderBrush" Value="#CFE0F7"/>
        <Setter Property="Effect" Value="{StaticResource SoftPanelShadow}"/>
    </Style>

    <Style x:Key="EmptyStateIconStyle" TargetType="Border">
        <Setter Property="Width" Value="58"/>
        <Setter Property="Height" Value="58"/>
        <Setter Property="CornerRadius" Value="18"/>
        <Setter Property="Background" Value="{StaticResource PrimaryAccentSoftBrush}"/>
        <Setter Property="BorderBrush" Value="#BFDBFE"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="EmptyStateStepStyle" TargetType="Border">
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Background" Value="#BFFFFFFF"/>
        <Setter Property="BorderBrush" Value="#DCE8F8"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="14"/>
    </Style>

    <Style x:Key="EmptyStateStepNumberStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style x:Key="EmptyStateStepTitleStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,7,0,0"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="EmptyStateStepDescriptionStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,5,0,0"/>
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="SecurityNoticeStyle" TargetType="Border">
        <Setter Property="Padding" Value="14,11"/>
        <Setter Property="Background" Value="#EAF2FF"/>
        <Setter Property="BorderBrush" Value="#C7DAF8"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
    </Style>

    <Style x:Key="ModuleViewHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="17"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="CloseViewButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource LifecycleButtonStyle}">
        <Setter Property="MinWidth" Value="68"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="Height" Value="30"/>
    </Style>

    <Style x:Key="ThemedScrollThumbStyle" TargetType="Thumb">
        <Setter Property="MinWidth" Value="7"/>
        <Setter Property="MinHeight" Value="34"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="Background" Value="#8CB6EE"/>
        <Setter Property="Opacity" Value="0.72"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="ThumbBody"
                            Background="{TemplateBinding Background}"
                            CornerRadius="5"
                            SnapsToDevicePixels="True"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbBody" Property="Background" Value="#5C94E8"/>
                            <Setter Property="Opacity" Value="0.9"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBody" Property="Background" Value="#2563EB"/>
                            <Setter Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.3"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="11"/>
        <Setter Property="MinWidth" Value="11"/>
        <Setter Property="Background" Value="#30C7D9F2"/>
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Border x:Name="TrackBackground"
                            Margin="1"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                        <Track x:Name="PART_Track"
                               IsDirectionReversed="True"
                               Orientation="{TemplateBinding Orientation}">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton x:Name="DecreaseButton"
                                              Command="{x:Static ScrollBar.PageUpCommand}"
                                              Focusable="False"
                                              Opacity="0"/>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ThemedScrollThumbStyle}"/>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton x:Name="IncreaseButton"
                                              Command="{x:Static ScrollBar.PageDownCommand}"
                                              Focusable="False"
                                              Opacity="0"/>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter Property="Width" Value="Auto"/>
                            <Setter Property="Height" Value="11"/>
                            <Setter Property="MinHeight" Value="11"/>
                            <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                            <Setter TargetName="DecreaseButton" Property="Command" Value="{x:Static ScrollBar.PageLeftCommand}"/>
                            <Setter TargetName="IncreaseButton" Property="Command" Value="{x:Static ScrollBar.PageRightCommand}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="TrackBackground" Property="Background" Value="#55C7D9F2"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
