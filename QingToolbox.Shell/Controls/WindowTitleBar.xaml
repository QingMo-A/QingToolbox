<UserControl x:Class="QingToolbox.Shell.Controls.WindowTitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
             xmlns:windowing="clr-namespace:QingToolbox.Shell.Windowing"
             Height="{x:Static windowing:WindowChromeMetrics.TitleBarHeight}"
             Style="{StaticResource WindowTitleBarStyle}"
             AutomationProperties.Name="{Binding AutomationName, RelativeSource={RelativeSource AncestorType=UserControl}}"
             PreviewMouseRightButtonUp="OnTitleBarRightClick">
    <Border Background="{Binding Background, RelativeSource={RelativeSource AncestorType=UserControl}}"
            BorderBrush="{StaticResource WindowTitleBarDividerBrush}"
            BorderThickness="0,0,0,1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="SystemMenuButton" Grid.Column="0"
                    Width="{x:Static windowing:WindowChromeMetrics.SystemMenuButtonWidth}" Height="47" Padding="11"
                    Style="{StaticResource WindowSystemMenuButtonStyle}"
                    ToolTip="{Binding SystemMenuText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    AutomationProperties.Name="{Binding SystemMenuText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    Click="OnSystemMenuClick"
                    PreviewMouseLeftButtonDown="OnSystemMenuLeftButtonDown"
                    PreviewMouseRightButtonUp="OnSystemMenuRightClick">
                <ContentPresenter Content="{Binding IconSource, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            </Button>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" IsHitTestVisible="False">
                <TextBlock Style="{StaticResource WindowTitleTextStyle}"
                           Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                <TextBlock Style="{StaticResource WindowSubtitleTextStyle}"
                           Text="{Binding Subtitle, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            </StackPanel>
            <ContentPresenter x:Name="AdditionalActionsPresenter" Grid.Column="2"
                              VerticalAlignment="Center"
                              Content="{Binding AdditionalActions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <ContentPresenter.Style>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Margin" Value="8,0"/>
                        <Style.Triggers>
                            <Trigger Property="Content" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Margin" Value="0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ContentPresenter.Style>
            </ContentPresenter>
            <StackPanel Grid.Column="3" Orientation="Horizontal"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="MinimizeButton" Style="{StaticResource WindowCaptionButtonStyle}"
                        Visibility="{Binding EffectiveShowMinimizeButton, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"
                        ToolTip="{Binding MinimizeText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        AutomationProperties.Name="{Binding MinimizeText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        Click="OnMinimizeClick"><TextBlock Text="&#xE921;" FontFamily="Segoe Fluent Icons"/></Button>
                <Button x:Name="MaximizeButton" Style="{StaticResource WindowCaptionButtonStyle}"
                        Visibility="{Binding EffectiveShowMaximizeButton, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"
                        ToolTip="{Binding MaximizeOrRestoreText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        AutomationProperties.Name="{Binding MaximizeOrRestoreText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        Click="OnMaximizeClick">
                    <TextBlock x:Name="MaximizeGlyphText" FontFamily="Segoe Fluent Icons" Text="&#xE922;"/>
                </Button>
                <Button x:Name="CloseButton" Style="{StaticResource WindowCloseButtonStyle}"
                        Visibility="{Binding ShowCloseButton, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"
                        ToolTip="{Binding CloseText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        AutomationProperties.Name="{Binding CloseText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        Click="OnCloseClick"><TextBlock Text="&#xE8BB;" FontFamily="Segoe Fluent Icons"/></Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
