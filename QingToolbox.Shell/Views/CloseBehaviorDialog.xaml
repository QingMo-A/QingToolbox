<Window x:Class="QingToolbox.Shell.Views.CloseBehaviorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="500" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="#F7FBFF">
    <Border Margin="18" Padding="26" Background="White" CornerRadius="18"
            BorderBrush="#DCE8F8" BorderThickness="1">
        <StackPanel>
            <TextBlock x:Name="HeadingText" FontSize="22" FontWeight="SemiBold" Foreground="#102A56"/>
            <TextBlock x:Name="DescriptionText" Margin="0,8,0,22" TextWrapping="Wrap" Foreground="#52647E"/>
            <Button x:Name="TrayButton" Margin="0,0,0,10" Padding="16" HorizontalContentAlignment="Left"
                    Click="OnTrayClick" AutomationProperties.AutomationId="MinimizeToNotificationArea">
                <StackPanel><TextBlock x:Name="TrayTitleText" FontWeight="SemiBold"/><TextBlock x:Name="TrayDescriptionText" Margin="0,4,0,0" TextWrapping="Wrap" Foreground="#60708A"/></StackPanel>
            </Button>
            <Button x:Name="ExitButton" Margin="0,0,0,16" Padding="16" HorizontalContentAlignment="Left"
                    Click="OnExitClick" AutomationProperties.AutomationId="ExitApplication">
                <StackPanel><TextBlock x:Name="ExitTitleText" FontWeight="SemiBold"/><TextBlock x:Name="ExitDescriptionText" Margin="0,4,0,0" TextWrapping="Wrap" Foreground="#60708A"/></StackPanel>
            </Button>
            <Button x:Name="CancelButton" HorizontalAlignment="Right" MinWidth="92" Padding="14,8"
                    IsCancel="True" Click="OnCancelClick" AutomationProperties.AutomationId="Cancel"/>
        </StackPanel>
    </Border>
</Window>
