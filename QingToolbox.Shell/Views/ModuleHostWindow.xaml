<Window x:Class="QingToolbox.Shell.Views.ModuleHostWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="900"
        Height="650"
        MinWidth="520"
        MinHeight="380"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource ShellBackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Margin="4,0,0,14"
                   Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Title}"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource PrimaryTextBrush}"/>
        <Border Grid.Row="1"
                Background="White"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
            <ContentControl x:Name="ModuleContent"/>
        </Border>
    </Grid>
</Window>
