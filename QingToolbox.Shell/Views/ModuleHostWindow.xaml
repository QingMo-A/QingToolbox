<Window x:Class="QingToolbox.Shell.Views.ModuleHostWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="900"
        Height="650"
        MinWidth="520"
        MinHeight="380"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource ShellBackgroundGradientBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Margin="4,0,0,16">
            <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Title}"
                       FontSize="22" FontWeight="SemiBold"
                       Foreground="{StaticResource StrongTextBrush}"/>
            <TextBlock Margin="0,4,0,0" Text="Qing Toolbox module"
                       FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
        </StackPanel>
        <Border Grid.Row="1"
                Padding="1"
                Style="{StaticResource LiquidGlassPanelStyle}">
            <Border Background="#E6FFFFFF" CornerRadius="23" Padding="12">
                <ContentControl x:Name="ModuleContent"/>
            </Border>
        </Border>
    </Grid>
</Window>
