<Window x:Class="QingToolbox.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="1100"
        Height="700"
        MinWidth="800"
        MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ShellBackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border x:Name="Sidebar"
                Grid.Column="0"
                Width="72"
                Padding="12,16,12,20"
                ClipToBounds="True"
                Background="{StaticResource SidebarBackgroundBrush}"
                MouseEnter="OnSidebarMouseEnter"
                MouseLeave="OnSidebarMouseLeave">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Margin="8,0,8,22" Height="36">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="30"
                            Height="30"
                            Background="#2563EB"
                            CornerRadius="8">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="Q"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                    </Border>
                    <TextBlock Grid.Column="1"
                               Text="Qing Toolbox"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Style="{StaticResource SidebarLabelStyle}"/>
                </Grid>

                <Button Grid.Row="1"
                        Command="{Binding SelectNavigationCommand}"
                        CommandParameter="Home">
                    <Button.Style>
                        <Style BasedOn="{StaticResource SidebarButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedNavigationKey}" Value="Home">
                                    <Setter Property="Tag" Value="Selected"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="⌂" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="Home"
                                   Style="{StaticResource SidebarLabelStyle}"/>
                    </Grid>
                </Button>

                <Button Grid.Row="2"
                        Command="{Binding SelectNavigationCommand}"
                        CommandParameter="Modules">
                    <Button.Style>
                        <Style BasedOn="{StaticResource SidebarButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedNavigationKey}" Value="Modules">
                                    <Setter Property="Tag" Value="Selected"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="◈" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="Modules"
                                   Style="{StaticResource SidebarLabelStyle}"/>
                    </Grid>
                </Button>

                <Button Grid.Row="3"
                        Command="{Binding SelectNavigationCommand}"
                        CommandParameter="Running">
                    <Button.Style>
                        <Style BasedOn="{StaticResource SidebarButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedNavigationKey}" Value="Running">
                                    <Setter Property="Tag" Value="Selected"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="●" FontSize="13" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="Running"
                                   Style="{StaticResource SidebarLabelStyle}"/>
                    </Grid>
                </Button>

                <Button Grid.Row="5"
                        Click="OnPinSidebarClick"
                        ToolTip="Pin or unpin the sidebar"
                        Style="{StaticResource SidebarButtonStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock FontSize="16" HorizontalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="□"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSidebarPinned}" Value="True">
                                            <Setter Property="Text" Value="■"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding PinLabel}"
                                   Style="{StaticResource SidebarLabelStyle}"/>
                    </Grid>
                </Button>

                <Button Grid.Row="6"
                        Command="{Binding SelectNavigationCommand}"
                        CommandParameter="Settings">
                    <Button.Style>
                        <Style BasedOn="{StaticResource SidebarButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedNavigationKey}" Value="Settings">
                                    <Setter Property="Tag" Value="Selected"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="⚙" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="Settings"
                                   Style="{StaticResource SidebarLabelStyle}"/>
                    </Grid>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="44,36">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Qing Toolbox"
                               FontSize="32"
                               FontWeight="SemiBold"
                               Foreground="#172033"/>
                    <TextBlock Margin="0,7,0,0"
                               Text="Modular Windows toolbox"
                               FontSize="15"
                               Foreground="#64748B"/>
                </StackPanel>
                <Button Grid.Column="1"
                        VerticalAlignment="Center"
                        Content="Refresh Modules"
                        Command="{Binding RefreshModulesCommand}"
                        Style="{StaticResource RefreshButtonStyle}"/>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,28,0,20"
                    Padding="16,12"
                    Background="#E8EEF8"
                    CornerRadius="7">
                <TextBlock Text="{Binding StatusMessage}" Foreground="#475569"/>
            </Border>

            <Grid Grid.Row="2">
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Text="No modules discovered. Add module packages to the runtime Modules directory."
                           Foreground="#64748B"
                           TextAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Modules.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Modules}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Modules.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ModuleCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="19"
                                                           FontWeight="SemiBold"
                                                           Foreground="#172033"/>
                                                <TextBlock Margin="10,4,0,0"
                                                           Text="{Binding Version, StringFormat=v{0}}"
                                                           Foreground="#64748B"/>
                                            </StackPanel>
                                            <TextBlock Margin="0,9,24,0"
                                                       Text="{Binding Description}"
                                                       TextWrapping="Wrap"
                                                       Foreground="#475569"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding State}"
                                                       FontWeight="SemiBold"
                                                       Foreground="#2563EB"
                                                       HorizontalAlignment="Right"/>
                                            <TextBlock Margin="0,8,0,0"
                                                       Text="{Binding ErrorCount, StringFormat=Errors: {0}}"
                                                       Foreground="#64748B"
                                                       HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
