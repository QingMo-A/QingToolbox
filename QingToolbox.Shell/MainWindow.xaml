<Window x:Class="QingToolbox.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        Title="{Binding Title}"
        Width="1100"
        Height="700"
        MinWidth="800"
        MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ShellBackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border x:Name="Sidebar"
                Grid.Column="0"
                Width="72"
                Padding="12,16,12,20"
                ClipToBounds="True"
                Background="{StaticResource SidebarBackgroundBrush}"
                MouseEnter="OnSidebarMouseEnter"
                MouseLeave="OnSidebarMouseLeave">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Margin="8,0,8,22" Height="36">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="30"
                            Height="30"
                            Background="#2563EB"
                            CornerRadius="8">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="Q"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                    </Border>
                    <TextBlock Grid.Column="1"
                               Text="Qing Toolbox"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Style="{StaticResource SidebarLabelStyle}"/>
                </Grid>

                <Button Grid.Row="1"
                        Command="{Binding SelectNavigationCommand}"
                        CommandParameter="Home">
                    <Button.Style>
                        <Style BasedOn="{StaticResource SidebarButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedNavigationKey}" Value="Home">
                                    <Setter Property="Tag" Value="Selected"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="28" Height="28" Background="#E2E8F0" CornerRadius="6">
                            <svgc:SvgViewbox
                                Style="{StaticResource ShellSvgIconStyle}"
                                Source="/QingToolbox.Shell;component/Assets/Icons/Nieobie/home.svg"/>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="Home"
                                   Style="{StaticResource SidebarLabelStyle}"/>
                    </Grid>
                </Button>

                <Button Grid.Row="2"
                        Command="{Binding SelectNavigationCommand}"
                        CommandParameter="Modules">
                    <Button.Style>
                        <Style BasedOn="{StaticResource SidebarButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedNavigationKey}" Value="Modules">
                                    <Setter Property="Tag" Value="Selected"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="28" Height="28" Background="#E2E8F0" CornerRadius="6">
                            <svgc:SvgViewbox
                                Style="{StaticResource ShellSvgIconStyle}"
                                Source="/QingToolbox.Shell;component/Assets/Icons/Nieobie/modules.svg"/>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="Modules"
                                   Style="{StaticResource SidebarLabelStyle}"/>
                    </Grid>
                </Button>

                <Button Grid.Row="3"
                        Command="{Binding SelectNavigationCommand}"
                        CommandParameter="Running">
                    <Button.Style>
                        <Style BasedOn="{StaticResource SidebarButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedNavigationKey}" Value="Running">
                                    <Setter Property="Tag" Value="Selected"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="28" Height="28" Background="#E2E8F0" CornerRadius="6">
                            <svgc:SvgViewbox
                                Style="{StaticResource ShellSvgIconStyle}"
                                Source="/QingToolbox.Shell;component/Assets/Icons/Nieobie/running.svg"/>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="Running"
                                   Style="{StaticResource SidebarLabelStyle}"/>
                    </Grid>
                </Button>

                <Button Grid.Row="5"
                        Click="OnPinSidebarClick"
                        ToolTip="Pin or unpin the sidebar"
                        Style="{StaticResource SidebarButtonStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="28" Height="28" Background="#E2E8F0" CornerRadius="6">
                            <svgc:SvgViewbox
                                Style="{StaticResource ShellSvgIconStyle}"
                                Source="/QingToolbox.Shell;component/Assets/Icons/Nieobie/pin.svg"/>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding PinLabel}"
                                   Style="{StaticResource SidebarLabelStyle}"/>
                    </Grid>
                </Button>

                <Button Grid.Row="6"
                        Command="{Binding SelectNavigationCommand}"
                        CommandParameter="Settings">
                    <Button.Style>
                        <Style BasedOn="{StaticResource SidebarButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedNavigationKey}" Value="Settings">
                                    <Setter Property="Tag" Value="Selected"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="28" Height="28" Background="#E2E8F0" CornerRadius="6">
                            <svgc:SvgViewbox
                                Style="{StaticResource ShellSvgIconStyle}"
                                Source="/QingToolbox.Shell;component/Assets/Icons/Nieobie/settings.svg"/>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="Settings"
                                   Style="{StaticResource SidebarLabelStyle}"/>
                    </Grid>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="44,36">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Qing Toolbox"
                               FontSize="32"
                               FontWeight="SemiBold"
                               Foreground="#172033"/>
                    <TextBlock Margin="0,7,0,0"
                               Text="Modular Windows toolbox"
                               FontSize="15"
                               Foreground="#64748B"/>
                </StackPanel>
                <Button Grid.Column="1"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="Refresh Modules"
                        Command="{Binding RefreshModulesCommand}"
                        Style="{StaticResource RefreshButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <svgc:SvgViewbox
                            Margin="0,0,8,0"
                            Style="{StaticResource CompactSvgIconStyle}"
                            Source="/QingToolbox.Shell;component/Assets/Icons/Nieobie/refresh.svg"/>
                        <TextBlock VerticalAlignment="Center" Text="Refresh Modules"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,28,0,20"
                    Padding="16,12"
                    Background="#E8EEF8"
                    CornerRadius="7">
                <TextBlock Text="{Binding StatusMessage}" Foreground="#475569"/>
            </Border>

            <Grid Grid.Row="2" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Total" Style="{StaticResource InfoLabelStyle}"/>
                        <TextBlock Text="{Binding TotalModuleCount}"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Valid" Style="{StaticResource InfoLabelStyle}"/>
                        <TextBlock Text="{Binding ValidModuleCount}"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="#15803D"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Failed" Style="{StaticResource InfoLabelStyle}"/>
                        <TextBlock Text="{Binding FailedModuleCount}"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="#B45309"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Not Loaded" Style="{StaticResource InfoLabelStyle}"/>
                        <TextBlock Text="{Binding NotLoadedModuleCount}"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="#2563EB"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="4" Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Loaded" Style="{StaticResource InfoLabelStyle}"/>
                        <TextBlock Text="{Binding LoadedModuleCount}"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="#0369A1"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="5" Style="{StaticResource SummaryCardStyle}" Margin="0">
                    <StackPanel>
                        <TextBlock Text="Running" Style="{StaticResource InfoLabelStyle}"/>
                        <TextBlock Text="{Binding RunningModuleCount}"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="#15803D"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Text="No modules discovered. Add module packages to the runtime Modules directory."
                           Foreground="#64748B"
                           TextAlignment="Center"
                           Grid.Column="0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Modules.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Modules}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Modules.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ModuleCardStyle}">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="19"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource PrimaryTextBrush}"/>
                                                <TextBlock Margin="10,4,0,0"
                                                           Text="{Binding Version, StringFormat=v{0}}"
                                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                                            </StackPanel>
                                            <Border Grid.Column="1"
                                                    Style="{StaticResource StateBadgeStyle}">
                                                <TextBlock Text="{Binding StateBadgeText}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#1D4ED8"/>
                                            </Border>
                                        </Grid>

                                        <TextBlock Margin="0,10,0,16"
                                                   Text="{Binding Description}"
                                                   TextWrapping="Wrap"
                                                   Foreground="#475569"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,16,12">
                                                <TextBlock Text="Runtime" Style="{StaticResource InfoLabelStyle}"/>
                                                <TextBlock Text="{Binding RuntimeType}" Style="{StaticResource InfoValueStyle}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="0,0,16,12">
                                                <TextBlock Text="Load mode" Style="{StaticResource InfoLabelStyle}"/>
                                                <TextBlock Text="{Binding LoadMode}" Style="{StaticResource InfoValueStyle}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Margin="0,0,0,12">
                                                <TextBlock Text="Author" Style="{StaticResource InfoLabelStyle}"/>
                                                <TextBlock Text="{Binding Author}" Style="{StaticResource InfoValueStyle}"/>
                                            </StackPanel>
                                        </Grid>

                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="Permissions" Style="{StaticResource InfoLabelStyle}"/>
                                            <TextBlock Text="{Binding PermissionsText}" Style="{StaticResource InfoValueStyle}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="Entry" Style="{StaticResource InfoLabelStyle}"/>
                                            <TextBlock Text="{Binding Entry}" Style="{StaticResource InfoValueStyle}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="Module directory" Style="{StaticResource InfoLabelStyle}"/>
                                            <TextBlock Text="{Binding ModuleDirectory}" Style="{StaticResource InfoValueStyle}"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Manifest" Style="{StaticResource InfoLabelStyle}"/>
                                            <TextBlock Text="{Binding ManifestPath}" Style="{StaticResource InfoValueStyle}"/>
                                        </StackPanel>

                                        <Grid Margin="0,16,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Runtime State:"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                                            <TextBlock Grid.Column="1"
                                                       Margin="8,0,0,0"
                                                       Text="{Binding RuntimeState}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource AccentBrush}"/>
                                        </Grid>

                                        <WrapPanel Margin="0,14,0,0">
                                            <Button AutomationProperties.Name="Load"
                                                    Command="{Binding DataContext.LoadModuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Id}"
                                                    IsEnabled="{Binding CanLoad}"
                                                    Style="{StaticResource LifecycleButtonStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                    <svgc:SvgViewbox Margin="0,0,6,0"
                                                                      Style="{StaticResource CompactSvgIconStyle}"
                                                                      Source="/QingToolbox.Shell;component/Assets/Icons/Nieobie/load.svg"/>
                                                    <TextBlock VerticalAlignment="Center" Text="Load"/>
                                                </StackPanel>
                                            </Button>
                                            <Button AutomationProperties.Name="Activate"
                                                    Command="{Binding DataContext.ActivateModuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Id}"
                                                    IsEnabled="{Binding CanActivate}"
                                                    Style="{StaticResource LifecycleButtonStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                    <svgc:SvgViewbox Margin="0,0,6,0"
                                                                      Style="{StaticResource CompactSvgIconStyle}"
                                                                      Source="/QingToolbox.Shell;component/Assets/Icons/Nieobie/activate.svg"/>
                                                    <TextBlock VerticalAlignment="Center" Text="Activate"/>
                                                </StackPanel>
                                            </Button>
                                            <Button AutomationProperties.Name="Deactivate"
                                                    Command="{Binding DataContext.DeactivateModuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Id}"
                                                    IsEnabled="{Binding CanDeactivate}"
                                                    Style="{StaticResource LifecycleButtonStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                    <svgc:SvgViewbox Margin="0,0,6,0"
                                                                      Style="{StaticResource CompactSvgIconStyle}"
                                                                      Source="/QingToolbox.Shell;component/Assets/Icons/Nieobie/deactivate.svg"/>
                                                    <TextBlock VerticalAlignment="Center" Text="Deactivate"/>
                                                </StackPanel>
                                            </Button>
                                            <Button AutomationProperties.Name="Unload"
                                                    Command="{Binding DataContext.UnloadModuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Id}"
                                                    IsEnabled="{Binding CanUnload}"
                                                    Style="{StaticResource LifecycleDangerButtonStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                    <svgc:SvgViewbox Margin="0,0,6,0"
                                                                      Style="{StaticResource CompactSvgIconStyle}"
                                                                      Source="/QingToolbox.Shell;component/Assets/Icons/Nieobie/unload.svg"/>
                                                    <TextBlock VerticalAlignment="Center" Text="Unload"/>
                                                </StackPanel>
                                            </Button>
                                            <Button AutomationProperties.Name="Open"
                                                    Command="{Binding DataContext.OpenModuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Id}"
                                                    IsEnabled="{Binding CanOpen}"
                                                    Style="{StaticResource LifecycleButtonStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                    <svgc:SvgViewbox Margin="0,0,6,0"
                                                                      Style="{StaticResource CompactSvgIconStyle}"
                                                                      Source="/QingToolbox.Shell;component/Assets/Icons/Nieobie/open.svg"/>
                                                    <TextBlock VerticalAlignment="Center" Text="Open"/>
                                                </StackPanel>
                                            </Button>
                                        </WrapPanel>

                                        <Border>
                                            <Border.Style>
                                                <Style BasedOn="{StaticResource RuntimeErrorPanelStyle}"
                                                       TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasRuntimeError}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <TextBlock Text="Runtime Error"
                                                           FontWeight="SemiBold"
                                                           Foreground="#991B1B"/>
                                                <TextBlock Margin="0,5,0,0"
                                                           Text="{Binding RuntimeError}"
                                                           TextWrapping="Wrap"
                                                           Foreground="#991B1B"/>
                                            </StackPanel>
                                        </Border>

                                        <Border>
                                            <Border.Style>
                                                <Style BasedOn="{StaticResource ErrorPanelStyle}" TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasErrors}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <TextBlock Text="{Binding ErrorSummary}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#9A3412"/>
                                                <ItemsControl Margin="0,6,0,0" ItemsSource="{Binding Errors}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Margin="0,2,0,0"
                                                                       Text="{Binding}"
                                                                       TextWrapping="Wrap"
                                                                       Foreground="#9A3412"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>

                                        <TextBlock Margin="0,12,0,0"
                                                   Text="{Binding ErrorSummary}"
                                                   Foreground="#15803D">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasErrors}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Column="1" Style="{StaticResource ModuleViewHostStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Padding="18,14"
                                BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <DockPanel>
                                <Button DockPanel.Dock="Right"
                                        AutomationProperties.Name="Close"
                                        Command="{Binding CloseModuleViewCommand}"
                                        IsEnabled="{Binding HasActiveModuleView}"
                                        Style="{StaticResource CloseViewButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <svgc:SvgViewbox Margin="0,0,6,0"
                                                          Style="{StaticResource CompactSvgIconStyle}"
                                                          Source="/QingToolbox.Shell;component/Assets/Icons/Nieobie/close.svg"/>
                                        <TextBlock VerticalAlignment="Center" Text="Close"/>
                                    </StackPanel>
                                </Button>
                                <TextBlock Text="{Binding ActiveModuleTitle}"
                                           Style="{StaticResource ModuleViewHeaderStyle}"/>
                            </DockPanel>
                        </Border>

                        <Grid Grid.Row="1">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="24"
                                       Text="Select a loaded module and click Open."
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource SecondaryTextBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasActiveModuleView}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <ContentControl Margin="1"
                                            Content="{Binding ActiveModuleView}">
                                <ContentControl.Style>
                                    <Style TargetType="ContentControl">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasActiveModuleView}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ContentControl.Style>
                            </ContentControl>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
