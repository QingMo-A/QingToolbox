<Window x:Class="QingToolbox.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        xmlns:behaviors="clr-namespace:QingToolbox.Shell.Behaviors"
        xmlns:controls="clr-namespace:QingToolbox.Shell.Controls"
        xmlns:windowing="clr-namespace:QingToolbox.Shell.Windowing"
        xmlns:settings="clr-namespace:QingToolbox.Core.Settings;assembly=QingToolbox.Core"
        Title="{Binding Title}"
        Width="1180"
        Height="760"
        MinWidth="500"
        MinHeight="580"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Icon="Assets/Branding/QingToolbox.ico"
        WindowStyle="None"
        ResizeMode="CanResize"
        windowing:WindowChromeBehavior.IsEnabled="True"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ShellBackgroundGradientBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{x:Static windowing:WindowChromeMetrics.TitleBarGridLength}"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <controls:WindowTitleBar Grid.Row="0"
                                 Title="{Binding Title}"
                                 MinimizeText="{Binding Strings[window.minimize]}"
                                 MaximizeText="{Binding Strings[window.maximize]}"
                                 RestoreText="{Binding Strings[window.restore]}"
                                 CloseText="{Binding Strings[window.close]}"
                                 SystemMenuText="{Binding Strings[window.systemMenu]}"
                                 AutomationName="{Binding Strings[window.titleBar]}">
            <controls:WindowTitleBar.IconSource>
                <svgc:SvgViewbox Width="24" Height="24"
                    Source="pack://application:,,,/QingToolbox.Shell;component/Assets/Branding/QingToolbox.Mark.svg"/>
            </controls:WindowTitleBar.IconSource>
            <controls:WindowTitleBar.AdditionalActions>
                <Button Style="{StaticResource WindowCaptionButtonStyle}"
                        ToolTip="{Binding Strings[floatingBadge.enableTooltip]}"
                        AutomationProperties.Name="{Binding Strings[floatingBadge.enable]}"
                        Click="OnFloatingBadgeClick">
                    <TextBlock Text="&#xE718;"
                               FontFamily="Segoe Fluent Icons"
                               FontSize="14"/>
                </Button>
            </controls:WindowTitleBar.AdditionalActions>
        </controls:WindowTitleBar>
        <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="1"
              ClipToBounds="True"
              IsHitTestVisible="False"
              Opacity="0.72">
            <Path Width="430"
                  Height="360"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Top"
                  Margin="-80,-100,0,0"
                  CacheMode="BitmapCache"
                  Data="M44,119 C62,35 166,-8 260,33 C354,73 414,155 374,238 C334,322 218,359 119,318 C20,277 25,203 44,119 Z"
                  Stretch="Fill">
                <Path.Fill>
                    <RadialGradientBrush Center="0.42,0.38"
                                         GradientOrigin="0.35,0.3"
                                         RadiusX="0.72"
                                         RadiusY="0.72">
                        <GradientStop Color="#704F8FF7" Offset="0"/>
                        <GradientStop Color="#2838BDF8" Offset="0.58"/>
                        <GradientStop Color="#004F8FF7" Offset="1"/>
                    </RadialGradientBrush>
                </Path.Fill>
                <Path.Effect>
                    <BlurEffect Radius="58"/>
                </Path.Effect>
                <Path.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <TranslateTransform X="0" Y="0"/>
                    </TransformGroup>
                </Path.RenderTransform>
                <Path.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever"
                                        AutoReverse="True">
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.X)"
                                                 From="-18" To="52"
                                                 Duration="0:0:24">
                                    <DoubleAnimation.EasingFunction>
                                        <SineEase EasingMode="EaseInOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                 From="-8" To="34"
                                                 Duration="0:0:19">
                                    <DoubleAnimation.EasingFunction>
                                        <SineEase EasingMode="EaseInOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                 From="0.96" To="1.06"
                                                 Duration="0:0:22"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                 From="1.03" To="0.96"
                                                 Duration="0:0:22"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Path.Triggers>
            </Path>

            <Path Width="520"
                  Height="430"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Center"
                  Margin="0,0,-180,-40"
                  CacheMode="BitmapCache"
                  Data="M31,162 C42,59 149,5 266,24 C383,43 484,117 474,224 C465,331 353,421 227,405 C101,389 20,265 31,162 Z"
                  Stretch="Fill">
                <Path.Fill>
                    <RadialGradientBrush Center="0.56,0.46"
                                         GradientOrigin="0.64,0.35"
                                         RadiusX="0.75"
                                         RadiusY="0.75">
                        <GradientStop Color="#665B8CFF" Offset="0"/>
                        <GradientStop Color="#305EEAD4" Offset="0.62"/>
                        <GradientStop Color="#005EEAD4" Offset="1"/>
                    </RadialGradientBrush>
                </Path.Fill>
                <Path.Effect>
                    <BlurEffect Radius="68"/>
                </Path.Effect>
                <Path.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <TranslateTransform X="0" Y="0"/>
                    </TransformGroup>
                </Path.RenderTransform>
                <Path.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever"
                                        AutoReverse="True">
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.X)"
                                                 From="42" To="-42"
                                                 Duration="0:0:29">
                                    <DoubleAnimation.EasingFunction>
                                        <SineEase EasingMode="EaseInOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                 From="28" To="-32"
                                                 Duration="0:0:25">
                                    <DoubleAnimation.EasingFunction>
                                        <SineEase EasingMode="EaseInOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                 From="1.05" To="0.95"
                                                 Duration="0:0:27"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                 From="0.96" To="1.05"
                                                 Duration="0:0:27"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Path.Triggers>
            </Path>

            <Path Width="360"
                  Height="300"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Bottom"
                  Margin="-120,0,0,-135"
                  CacheMode="BitmapCache"
                  Data="M26,111 C51,30 141,-5 224,25 C307,55 352,129 329,205 C306,281 218,310 128,284 C38,258 1,192 26,111 Z"
                  Stretch="Fill"
                  Opacity="0.72">
                <Path.Fill>
                    <RadialGradientBrush Center="0.5,0.48"
                                         GradientOrigin="0.42,0.58"
                                         RadiusX="0.78"
                                         RadiusY="0.78">
                        <GradientStop Color="#5C8B5CF6" Offset="0"/>
                        <GradientStop Color="#264F8FF7" Offset="0.65"/>
                        <GradientStop Color="#008B5CF6" Offset="1"/>
                    </RadialGradientBrush>
                </Path.Fill>
                <Path.Effect>
                    <BlurEffect Radius="62"/>
                </Path.Effect>
                <Path.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <TranslateTransform X="0" Y="0"/>
                    </TransformGroup>
                </Path.RenderTransform>
                <Path.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever"
                                        AutoReverse="True">
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.X)"
                                                 From="-35" To="38"
                                                 Duration="0:0:26">
                                    <DoubleAnimation.EasingFunction>
                                        <SineEase EasingMode="EaseInOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                 From="12" To="-28"
                                                 Duration="0:0:21">
                                    <DoubleAnimation.EasingFunction>
                                        <SineEase EasingMode="EaseInOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                 From="0.97" To="1.08"
                                                 Duration="0:0:30"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                 From="1.06" To="0.96"
                                                 Duration="0:0:30"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Path.Triggers>
            </Path>
        </Grid>

        <Border x:Name="Sidebar"
                Grid.Column="0"
                Width="72"
                Padding="12,16,12,20"
                ClipToBounds="True"
                Background="{StaticResource SidebarBackgroundBrush}"
                MouseEnter="OnSidebarMouseEnter"
                MouseLeave="OnSidebarMouseLeave">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Margin="8,0,8,22" Height="36"
                      AutomationProperties.Name="QingToolbox">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <svgc:SvgViewbox Width="32" Height="32"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Source="pack://application:,,,/QingToolbox.Shell;component/Assets/Branding/QingToolbox.Mark.svg"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding Strings[app.name]}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               Style="{StaticResource SidebarLabelStyle}"/>
                </Grid>

                <Button Grid.Row="1"
                        AutomationProperties.Name="Home"
                        Command="{Binding SelectNavigationCommand}"
                        CommandParameter="Home">
                    <Button.Style>
                        <Style BasedOn="{StaticResource SidebarButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedNavigationKey}" Value="Home">
                                    <Setter Property="Tag" Value="Selected"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource SidebarIconContainerStyle}">
                            <TextBlock Text="&#xE80F;" Style="{StaticResource FluentIconStyle}"/>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Strings[nav.home]}"
                                   Style="{StaticResource SidebarLabelStyle}"/>
                    </Grid>
                </Button>

                <Button Grid.Row="2"
                        AutomationProperties.Name="Modules"
                        Command="{Binding SelectNavigationCommand}"
                        CommandParameter="Modules">
                    <Button.Style>
                        <Style BasedOn="{StaticResource SidebarButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedNavigationKey}" Value="Modules">
                                    <Setter Property="Tag" Value="Selected"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource SidebarIconContainerStyle}">
                            <TextBlock Text="&#xE71D;" Style="{StaticResource FluentIconStyle}"/>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Strings[nav.modules]}"
                                   Style="{StaticResource SidebarLabelStyle}"/>
                    </Grid>
                </Button>

                <Button Grid.Row="3"
                        AutomationProperties.Name="Running"
                        Command="{Binding SelectNavigationCommand}"
                        CommandParameter="Running">
                    <Button.Style>
                        <Style BasedOn="{StaticResource SidebarButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedNavigationKey}" Value="Running">
                                    <Setter Property="Tag" Value="Selected"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource SidebarIconContainerStyle}">
                            <TextBlock Text="&#xE768;" Style="{StaticResource FluentIconStyle}"/>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Strings[nav.running]}"
                                   Style="{StaticResource SidebarLabelStyle}"/>
                    </Grid>
                </Button>

                <Button Grid.Row="5"
                        Click="OnPinSidebarClick"
                        ToolTip="{Binding Strings[sidebar.pinTooltip]}"
                        Style="{StaticResource SidebarButtonStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource SidebarIconContainerStyle}">
                            <TextBlock Text="&#xE718;" Style="{StaticResource FluentIconStyle}"/>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding PinLabel}"
                                   Style="{StaticResource SidebarLabelStyle}"/>
                    </Grid>
                </Button>

                <Button Grid.Row="6"
                        AutomationProperties.Name="Settings"
                        Command="{Binding SelectNavigationCommand}"
                        CommandParameter="Settings">
                    <Button.Style>
                        <Style BasedOn="{StaticResource SidebarButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedNavigationKey}" Value="Settings">
                                    <Setter Property="Tag" Value="Selected"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource SidebarIconContainerStyle}">
                            <TextBlock Text="&#xE713;" Style="{StaticResource FluentIconStyle}"/>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Strings[nav.settings]}"
                                   Style="{StaticResource SidebarLabelStyle}"/>
                    </Grid>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Margin" Value="34,28,34,30"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCompactWindow}" Value="True">
                            <Setter Property="Margin" Value="14,16,14,18"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsHomeSelected}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="{Binding PageTitle}"
                               FontSize="30"
                               FontWeight="SemiBold"
                               Foreground="#172033"/>
                    <TextBlock Margin="0,7,0,0"
                               Text="{Binding PageSubtitle}"
                               FontSize="15"
                               Foreground="#64748B"/>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Visibility="{Binding IsModulesSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCompactWindow}" Value="True">
                                    <Setter Property="Grid.Row" Value="1"/>
                                    <Setter Property="Grid.Column" Value="0"/>
                                    <Setter Property="Margin" Value="0,14,0,0"/>
                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Button Margin="0,0,10,0" Command="{Binding CheckModuleUpdatesCommand}"
                            IsEnabled="{Binding CanCheckModuleUpdates}"
                            Style="{StaticResource SecondaryActionButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE895;" Style="{StaticResource CompactFluentIconStyle}"/>
                            <TextBlock Text="{Binding Strings[moduleUpdate.check]}"/>
                        </StackPanel>
                    </Button>
                    <Button Margin="0,0,10,0"
                            AutomationProperties.Name="Import Module"
                            Command="{Binding ImportModuleCommand}"
                            Style="{StaticResource SecondaryActionButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8E5;" Style="{StaticResource CompactFluentIconStyle}"/>
                            <TextBlock VerticalAlignment="Center" Text="{Binding Strings[modules.import]}"/>
                        </StackPanel>
                    </Button>
                    <Button AutomationProperties.Name="Refresh Modules"
                            Command="{Binding RefreshModulesCommand}"
                            Style="{StaticResource RefreshButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" Style="{StaticResource CompactFluentIconStyle}"/>
                            <TextBlock VerticalAlignment="Center" Text="{Binding Strings[modules.refresh]}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,20,0,16"
                    Visibility="{Binding IsModulesSelected, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Style="{StaticResource StatusMessageStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#475569"/>
                    <TextBlock Margin="0,4,0,0" Text="{Binding ModuleUpdateSummary}" Foreground="#31598F"/>
                    <TextBlock Margin="0,2,0,0" Text="{Binding ModuleUpdateLastChecked}" FontSize="12" Foreground="#64748B"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="2" Margin="0,0,0,20">
                <Grid.Style>
                    <Style TargetType="Grid" BasedOn="{StaticResource PageTransitionStyle}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsModulesSelected}" Value="True"/>
                                    <Condition Binding="{Binding HasModules}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                            <DataTrigger Binding="{Binding IsCompactWindow}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding Strings[summary.total]}" Style="{StaticResource SummaryLabelStyle}"/>
                        <TextBlock Text="{Binding TotalModuleCount}"
                                   Style="{StaticResource SummaryNumberStyle}"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding Strings[summary.valid]}" Style="{StaticResource SummaryLabelStyle}"/>
                        <TextBlock Text="{Binding ValidModuleCount}"
                                   Style="{StaticResource SummaryNumberStyle}"
                                   Foreground="#15803D"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding Strings[summary.failed]}" Style="{StaticResource SummaryLabelStyle}"/>
                        <TextBlock Text="{Binding FailedModuleCount}"
                                   Style="{StaticResource SummaryNumberStyle}"
                                   Foreground="#B45309"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding Strings[summary.notLoaded]}" Style="{StaticResource SummaryLabelStyle}"/>
                        <TextBlock Text="{Binding NotLoadedModuleCount}"
                                   Style="{StaticResource SummaryNumberStyle}"
                                   Foreground="#2563EB"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="4" Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding Strings[summary.loaded]}" Style="{StaticResource SummaryLabelStyle}"/>
                        <TextBlock Text="{Binding LoadedModuleCount}"
                                   Style="{StaticResource SummaryNumberStyle}"
                                   Foreground="#0369A1"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="5" Style="{StaticResource SummaryCardStyle}" Margin="0">
                    <StackPanel>
                        <TextBlock Text="{Binding Strings[summary.running]}" Style="{StaticResource SummaryLabelStyle}"/>
                        <TextBlock Text="{Binding RunningModuleCount}"
                                   Style="{StaticResource SummaryNumberStyle}"
                                   Foreground="#15803D"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="3"
                  Style="{StaticResource PageTransitionStyle}"
                  Visibility="{Binding IsModulesSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition>
                        <ColumnDefinition.Style>
                            <Style TargetType="ColumnDefinition">
                                <Setter Property="Width" Value="2*"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedModule}" Value="{x:Null}">
                                        <Setter Property="Width" Value="0"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsCompactWindow}" Value="True">
                                        <Setter Property="Width" Value="0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ColumnDefinition.Style>
                    </ColumnDefinition>
                </Grid.ColumnDefinitions>
                <ScrollViewer Grid.ColumnSpan="2"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Modules.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <Border Margin="2,2,10,12" Style="{StaticResource EmptyStateCardStyle}">
                        <StackPanel>
                            <Border HorizontalAlignment="Left" Style="{StaticResource EmptyStateIconStyle}">
                                <TextBlock Text="&#xE71D;" FontFamily="Segoe Fluent Icons"
                                           FontSize="28" Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Margin="0,18,0,0" Text="{Binding Strings[empty.modules.title]}"
                                       FontSize="23" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryTextBrush}" TextWrapping="Wrap"/>
                            <TextBlock Margin="0,8,0,0" Text="{Binding Strings[empty.modules.description]}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontSize="14" TextWrapping="Wrap"/>
                            <UniformGrid Margin="0,22,0,0" Columns="3" Rows="1">
                                <Border Margin="0,0,5,0" Style="{StaticResource EmptyStateStepStyle}">
                                    <StackPanel>
                                        <TextBlock Text="1" Style="{StaticResource EmptyStateStepNumberStyle}"/>
                                        <TextBlock Text="{Binding Strings[empty.modules.step.obtain.title]}"
                                                   Style="{StaticResource EmptyStateStepTitleStyle}"/>
                                        <TextBlock Text="{Binding Strings[empty.modules.step.obtain.description]}"
                                                   Style="{StaticResource EmptyStateStepDescriptionStyle}"/>
                                    </StackPanel>
                                </Border>
                                <Border Margin="5,0" Style="{StaticResource EmptyStateStepStyle}">
                                    <StackPanel>
                                        <TextBlock Text="2" Style="{StaticResource EmptyStateStepNumberStyle}"/>
                                        <TextBlock Text="{Binding Strings[empty.modules.step.import.title]}"
                                                   Style="{StaticResource EmptyStateStepTitleStyle}"/>
                                        <TextBlock Text="{Binding Strings[empty.modules.step.import.description]}"
                                                   Style="{StaticResource EmptyStateStepDescriptionStyle}"/>
                                    </StackPanel>
                                </Border>
                                <Border Margin="5,0,0,0" Style="{StaticResource EmptyStateStepStyle}">
                                    <StackPanel>
                                        <TextBlock Text="3" Style="{StaticResource EmptyStateStepNumberStyle}"/>
                                        <TextBlock Text="{Binding Strings[empty.modules.step.load.title]}"
                                                   Style="{StaticResource EmptyStateStepTitleStyle}"/>
                                        <TextBlock Text="{Binding Strings[empty.modules.step.load.description]}"
                                                   Style="{StaticResource EmptyStateStepDescriptionStyle}"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                            <WrapPanel Margin="0,12,0,0">
                                <Button Margin="0,0,10,10" Command="{Binding ImportModuleCommand}"
                                        AutomationProperties.Name="{Binding Strings[empty.modules.import]}"
                                        Style="{StaticResource PrimaryActionButtonStyle}">
                                    <TextBlock Text="{Binding Strings[empty.modules.import]}"/>
                                </Button>
                                <Button Margin="0,0,10,10" Command="{Binding OpenUserModulesDirectoryCommand}"
                                        AutomationProperties.Name="{Binding Strings[empty.modules.openFolder]}"
                                        Style="{StaticResource SecondaryActionButtonStyle}">
                                    <TextBlock Text="{Binding Strings[empty.modules.openFolder]}"/>
                                </Button>
                                <Button Margin="0,0,0,10" Command="{Binding RefreshModulesCommand}"
                                        AutomationProperties.Name="{Binding Strings[empty.modules.refresh]}"
                                        Style="{StaticResource SecondaryActionButtonStyle}">
                                    <TextBlock Text="{Binding Strings[empty.modules.refresh]}"/>
                                </Button>
                            </WrapPanel>
                            <Border Margin="0,8,0,0" Style="{StaticResource SecurityNoticeStyle}">
                                <TextBlock Text="{Binding Strings[empty.modules.securityNotice]}"
                                           TextWrapping="Wrap" Foreground="#39577D"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </ScrollViewer>

                <ScrollViewer Grid.Column="0"
                              behaviors:SmoothScrollBehavior.IsEnabled="True"
                              VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsCompactWindow}" Value="True"/>
                                        <Condition Binding="{Binding SelectedModule}" Value="{x:Null}"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsCompactWindow}" Value="True"/>
                                        <Condition Binding="{Binding HasSelectedModule}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <ItemsControl ItemsSource="{Binding Modules}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Modules.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ModuleCardCompactStyle}">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    VerticalAlignment="Center"
                                                    Style="{StaticResource ModuleIconContainerStyle}">
                                                <Grid>
                                                <svgc:SvgViewbox
                                                    Style="{StaticResource ModuleIconStyle}"
                                                    Visibility="{Binding HasIcon, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    Source="{Binding IconPath, Converter={StaticResource ModuleIconSourceConverter}}"/>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock"
                                                               BasedOn="{StaticResource DefaultModuleFluentIconStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasIcon}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                </Grid>
                                            </Border>
                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        Orientation="Horizontal">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontSize="19"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource PrimaryTextBrush}"/>
                                                <TextBlock Margin="10,4,0,0"
                                                           Text="{Binding Version, StringFormat=v{0}}"
                                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                                            </StackPanel>
                                            <Border Grid.Column="2"
                                                    Margin="12,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Style="{StaticResource StateBadgeStyle}">
                                                <TextBlock Text="{Binding DisplayRuntimeState}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#1D4ED8"/>
                                            </Border>
                                        </Grid>

                                        <TextBlock Margin="0,10,0,16"
                                                   Text="{Binding DisplayDescription}"
                                                   TextWrapping="Wrap"
                                                   Foreground="#475569"/>
                                        <Border Margin="0,0,0,12" Padding="10,6" CornerRadius="10" Background="#EEF5FF">
                                            <TextBlock Text="{Binding DisplayUpdateStatus}" TextWrapping="Wrap" Foreground="#31598F"/>
                                        </Border>

                                        <CheckBox Margin="0,0,0,12"
                                                  Content="{Binding DataContext.Strings[startup.moduleLabel], RelativeSource={RelativeSource AncestorType=Window}}"
                                                  ToolTip="{Binding DataContext.Strings[startup.moduleDescription], RelativeSource={RelativeSource AncestorType=Window}}"
                                                  AutomationProperties.Name="{Binding DataContext.Strings[startup.moduleLabel], RelativeSource={RelativeSource AncestorType=Window}}"
                                                  IsChecked="{Binding IsStartupEnabled, Mode=TwoWay}"
                                                  IsEnabled="{Binding CanChangeStartupAuthorization}"
                                                  Command="{Binding DataContext.ToggleModuleStartupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding}"/>
                                        <TextBlock Margin="0,0,0,8" Text="{Binding StartupAuthorizationMessage}"
                                                   TextWrapping="Wrap" Foreground="{StaticResource SecondaryTextBrush}"/>

                                        <Button HorizontalAlignment="Left"
                                                Command="{Binding DataContext.SelectModuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource SecondaryActionButtonStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE946;" Style="{StaticResource CompactFluentIconStyle}"/>
                                                <TextBlock Text="{Binding DataContext.Strings[modules.details], RelativeSource={RelativeSource AncestorType=Window}}"/>
                                            </StackPanel>
                                        </Button>

                                        <Grid Margin="0,16,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding DataContext.Strings[module.runtimeState], RelativeSource={RelativeSource AncestorType=Window}}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                                            <TextBlock Grid.Column="1"
                                                       Margin="8,0,0,0"
                                                       Text="{Binding DisplayRuntimeState}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource AccentBrush}"/>
                                        </Grid>

                                        <WrapPanel Margin="0,14,0,0">
                                            <Button AutomationProperties.Name="Load"
                                                    Command="{Binding DataContext.LoadModuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Id}"
                                                    IsEnabled="{Binding CanLoad}"
                                                    Style="{StaticResource PrimaryActionButtonStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Margin="0,0,6,0" Text="&#xE896;" Style="{StaticResource CompactFluentIconStyle}"/>
                                                    <TextBlock VerticalAlignment="Center" Text="{Binding DataContext.Strings[modules.load], RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                </StackPanel>
                                            </Button>
                                            <Button AutomationProperties.Name="Activate"
                                                    Command="{Binding DataContext.ActivateModuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Id}"
                                                    IsEnabled="{Binding CanActivate}"
                                                    Style="{StaticResource SecondaryActionButtonStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Margin="0,0,6,0" Text="&#xE768;" Style="{StaticResource CompactFluentIconStyle}"/>
                                                    <TextBlock VerticalAlignment="Center" Text="{Binding DataContext.Strings[modules.activate], RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                </StackPanel>
                                            </Button>
                                            <Button AutomationProperties.Name="Deactivate"
                                                    Command="{Binding DataContext.DeactivateModuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Id}"
                                                    IsEnabled="{Binding CanDeactivate}"
                                                    Style="{StaticResource SecondaryActionButtonStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Margin="0,0,6,0" Text="&#xE769;" Style="{StaticResource CompactFluentIconStyle}"/>
                                                    <TextBlock VerticalAlignment="Center" Text="{Binding DataContext.Strings[modules.deactivate], RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                </StackPanel>
                                            </Button>
                                            <Button AutomationProperties.Name="Unload"
                                                    Command="{Binding DataContext.UnloadModuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Id}"
                                                    IsEnabled="{Binding CanUnload}"
                                                    Style="{StaticResource DangerActionButtonStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Margin="0,0,6,0" Text="&#xE74D;" Style="{StaticResource CompactFluentIconStyle}"/>
                                                    <TextBlock VerticalAlignment="Center" Text="{Binding DataContext.Strings[modules.unload], RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                </StackPanel>
                                            </Button>
                                            <Button AutomationProperties.Name="Open"
                                                    Command="{Binding DataContext.OpenModuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Id}"
                                                    IsEnabled="{Binding CanOpen}"
                                                    Style="{StaticResource PrimaryActionButtonStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Margin="0,0,6,0" Text="&#xE8A7;" Style="{StaticResource CompactFluentIconStyle}"/>
                                                    <TextBlock VerticalAlignment="Center" Text="{Binding DataContext.Strings[modules.open], RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                </StackPanel>
                                            </Button>
                                        </WrapPanel>

                                        <Border>
                                            <Border.Style>
                                                <Style BasedOn="{StaticResource RuntimeErrorPanelStyle}"
                                                       TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasRuntimeError}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <TextBlock Text="{Binding DataContext.Strings[module.runtimeError], RelativeSource={RelativeSource AncestorType=Window}}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#991B1B"/>
                                                <TextBlock Margin="0,5,0,0"
                                                           Text="{Binding RuntimeError}"
                                                           TextWrapping="Wrap"
                                                           Foreground="#991B1B"/>
                                            </StackPanel>
                                        </Border>

                                        <Border>
                                            <Border.Style>
                                                <Style BasedOn="{StaticResource ErrorPanelStyle}" TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasErrors}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <TextBlock Text="{Binding ErrorSummary}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#9A3412"/>
                                                <ItemsControl Margin="0,6,0,0" ItemsSource="{Binding Errors}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Margin="0,2,0,0"
                                                                       Text="{Binding}"
                                                                       TextWrapping="Wrap"
                                                                       Foreground="#9A3412"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>

                                        <TextBlock Margin="0,12,0,0"
                                                   Text="{Binding ErrorSummary}"
                                                   Foreground="#15803D">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasErrors}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Column="1">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource WorkspacePanelStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCompactWindow}" Value="True">
                                    <Setter Property="Grid.Column" Value="0"/>
                                </DataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsCompactWindow}" Value="True"/>
                                        <Condition Binding="{Binding HasSelectedModule}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <ScrollViewer behaviors:SmoothScrollBehavior.IsEnabled="True"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="24" DataContext="{Binding SelectedModule}">
                            <Button Margin="0,0,0,14" HorizontalAlignment="Left"
                                    Command="{Binding DataContext.CloseModuleDetailsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    >
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.IsCompactWindow, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="&#xE72B;" FontFamily="Segoe Fluent Icons"/>
                            </Button>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource ModuleIconContainerStyle}">
                                    <Grid>
                                        <svgc:SvgViewbox Style="{StaticResource ModuleIconStyle}"
                                                         Visibility="{Binding HasIcon, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                         Source="{Binding IconPath, Converter={StaticResource ModuleIconSourceConverter}}"/>
                                        <TextBlock Style="{StaticResource DefaultModuleFluentIconStyle}"/>
                                    </Grid>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontSize="22" FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryTextBrush}"/>
                                    <TextBlock Margin="0,4,0,0"
                                               Text="{Binding Version, StringFormat=v{0}}"
                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                </StackPanel>
                            </Grid>

                            <Border Margin="0,18,0,16" HorizontalAlignment="Left"
                                    Style="{StaticResource StateBadgeStyle}">
                                <TextBlock Text="{Binding DisplayRuntimeState}"
                                           FontWeight="SemiBold" Foreground="#1D4ED8"/>
                            </Border>
                            <TextBlock Text="{Binding DisplayDescription}"
                                       TextWrapping="Wrap" Foreground="#475569"/>
                            <Border Margin="0,14,0,0" Padding="12,9" CornerRadius="10" Background="#EEF5FF">
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayUpdateStatus}" Foreground="#31598F" FontWeight="SemiBold"/>
                                    <TextBlock Margin="0,5,0,0" Text="{Binding DisplayUpdateReleaseNote}"
                                               Visibility="{Binding HasUpdateReleaseNote, Converter={StaticResource BooleanToVisibilityConverter}}"
                                               TextWrapping="Wrap" Foreground="#526B8B"/>
                                </StackPanel>
                            </Border>
                            <CheckBox Margin="0,14,0,0"
                                      Content="{Binding DataContext.Strings[startup.moduleLabel], RelativeSource={RelativeSource AncestorType=Window}}"
                                      ToolTip="{Binding DataContext.Strings[startup.moduleDescription], RelativeSource={RelativeSource AncestorType=Window}}"
                                      AutomationProperties.Name="{Binding DataContext.Strings[startup.moduleLabel], RelativeSource={RelativeSource AncestorType=Window}}"
                                      IsChecked="{Binding IsStartupEnabled, Mode=TwoWay}"
                                      IsEnabled="{Binding CanChangeStartupAuthorization}"
                                      Command="{Binding DataContext.ToggleModuleStartupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                      CommandParameter="{Binding}"/>
                            <TextBlock Margin="0,5,0,0" Text="{Binding StartupAuthorizationMessage}"
                                       TextWrapping="Wrap" Foreground="{StaticResource SecondaryTextBrush}"/>

                            <Border Margin="0,22,0,18" Height="1" Background="#E2E8F0"/>
                            <TextBlock Text="{Binding DataContext.Strings[modules.details], RelativeSource={RelativeSource AncestorType=Window}}"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryTextBrush}"/>

                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,16,14">
                                    <TextBlock Text="{Binding DataContext.Strings[module.runtime], RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource InfoLabelStyle}"/>
                                    <TextBlock Text="{Binding RuntimeType}" Style="{StaticResource InfoValueStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,0,14">
                                    <TextBlock Text="{Binding DataContext.Strings[module.loadMode], RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource InfoLabelStyle}"/>
                                    <TextBlock Text="{Binding LoadMode}" Style="{StaticResource InfoValueStyle}"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Margin="0,0,0,14">
                                <TextBlock Text="{Binding DataContext.Strings[module.author], RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource InfoLabelStyle}"/>
                                <TextBlock Text="{Binding Author}" Style="{StaticResource InfoValueStyle}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,14">
                                <TextBlock Text="{Binding DataContext.Strings[module.permissions], RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource InfoLabelStyle}"/>
                                <TextBlock Text="{Binding PermissionsText}" Style="{StaticResource InfoValueStyle}"/>
                            </StackPanel>

                            <Expander Header="{Binding DataContext.Strings[modules.advanced], RelativeSource={RelativeSource AncestorType=Window}}"
                                      Style="{StaticResource ModuleDetailsExpanderStyle}">
                                <StackPanel Margin="0,12,0,0">
                                    <TextBlock Text="{Binding DataContext.Strings[module.entry], RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource InfoLabelStyle}"/>
                                    <TextBlock Margin="0,0,0,12" Text="{Binding Entry}" Style="{StaticResource InfoValueStyle}"/>
                                    <TextBlock Text="{Binding DataContext.Strings[module.directory], RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource InfoLabelStyle}"/>
                                    <TextBlock Margin="0,0,0,12" Text="{Binding ModuleDirectory}" Style="{StaticResource InfoValueStyle}"/>
                                    <TextBlock Text="{Binding DataContext.Strings[module.manifest], RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource InfoLabelStyle}"/>
                                    <TextBlock Margin="0,0,0,12" Text="{Binding ManifestPath}" Style="{StaticResource InfoValueStyle}"/>
                                    <TextBlock Text="{Binding DataContext.Strings[module.minimumHostVersion], RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource InfoLabelStyle}"/>
                                    <TextBlock Text="{Binding MinimumHostVersion}" Style="{StaticResource InfoValueStyle}"/>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <Grid Grid.Row="2" Grid.RowSpan="2"
                  Style="{StaticResource PageTransitionStyle}"
                  Visibility="{Binding IsHomeSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ScrollViewer Margin="2,0,8,0"
                              behaviors:SmoothScrollBehavior.IsEnabled="True"
                              HorizontalContentAlignment="Stretch"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel HorizontalAlignment="Stretch">
                        <Border Margin="0,2,0,18"
                                Visibility="{Binding HasNoModules, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Style="{StaticResource EmptyStateCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Margin="0,0,20,0" Style="{StaticResource EmptyStateIconStyle}">
                                    <TextBlock Text="&#xE8F1;" FontFamily="Segoe Fluent Icons" FontSize="27"
                                               Foreground="{StaticResource AccentBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Strings[empty.home.title]}" FontSize="20"
                                               FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Margin="0,7,0,0" Text="{Binding Strings[empty.home.description]}"
                                               Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                                    <WrapPanel Margin="0,14,0,0">
                                        <Button Margin="0,0,10,8" Command="{Binding ImportModuleCommand}"
                                                AutomationProperties.Name="{Binding Strings[empty.home.importFirst]}"
                                                Style="{StaticResource PrimaryActionButtonStyle}">
                                            <TextBlock Text="{Binding Strings[empty.home.importFirst]}"/>
                                        </Button>
                                        <Button Margin="0,0,0,8" Command="{Binding OpenUserModulesDirectoryCommand}"
                                                AutomationProperties.Name="{Binding Strings[empty.home.openFolder]}"
                                                Style="{StaticResource SecondaryActionButtonStyle}">
                                            <TextBlock Text="{Binding Strings[empty.home.openFolder]}"/>
                                        </Button>
                                    </WrapPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <StackPanel Visibility="{Binding HasModules, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border Padding="28" CornerRadius="22" BorderThickness="0"
                                    Effect="{StaticResource FloatingPanelShadow}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#2864F0" Offset="0"/>
                                    <GradientStop Color="#5C9DFA" Offset="0.62"/>
                                    <GradientStop Color="#A7D8FF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition>
                                        <ColumnDefinition.Style>
                                            <Style TargetType="ColumnDefinition">
                                                <Setter Property="Width" Value="180"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCompactWindow}" Value="True">
                                                        <Setter Property="Width" Value="0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ColumnDefinition.Style>
                                    </ColumnDefinition>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Strings[home.systemStatus]}"
                                               Foreground="#DCEBFF" FontSize="13"/>
                                    <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                        <TextBlock Text="{Binding Strings[home.statusHealthy]}"
                                                   Foreground="White" FontSize="25" FontWeight="SemiBold"/>
                                        <TextBlock Margin="10,3,0,0" Text="&#xE73E;"
                                                   FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="#D1FAE5"/>
                                    </StackPanel>
                                    <TextBlock Margin="0,8,0,18" Text="{Binding Strings[home.systemDescription]}"
                                               Foreground="#EAF3FF" TextWrapping="Wrap"/>
                                    <Button Width="128" HorizontalAlignment="Left"
                                            Command="{Binding SelectNavigationCommand}"
                                            CommandParameter="Modules"
                                            Style="{StaticResource SecondaryActionButtonStyle}">
                                        <TextBlock Text="{Binding Strings[home.browseModules]}"/>
                                    </Button>
                                </StackPanel>
                                <Border Grid.Column="1" Width="132" Height="132"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Background="#28FFFFFF" CornerRadius="38">
                                    <TextBlock Text="&#xE71D;" FontFamily="Segoe Fluent Icons"
                                               FontSize="58" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>

                        <UniformGrid Margin="0,18,0,0" Columns="2" Rows="2">
                            <Border Margin="0,0,9,9" Padding="20" Height="105" Style="{StaticResource SummaryCardStyle}">
                                <StackPanel><TextBlock Text="{Binding Strings[home.installedModules]}" Style="{StaticResource SummaryLabelStyle}"/><TextBlock Margin="0,7,0,0" Text="{Binding TotalModuleCount}" Style="{StaticResource SummaryNumberStyle}"/></StackPanel>
                            </Border>
                            <Border Margin="9,0,0,9" Padding="20" Height="105" Style="{StaticResource SummaryCardStyle}">
                                <StackPanel><TextBlock Text="{Binding Strings[home.runningModules]}" Style="{StaticResource SummaryLabelStyle}"/><TextBlock Margin="0,7,0,0" Text="{Binding RunningModuleCount}" Style="{StaticResource SummaryNumberStyle}" Foreground="#059669"/></StackPanel>
                            </Border>
                            <Border Margin="0,9,9,0" Padding="20" Height="105" Style="{StaticResource SummaryCardStyle}">
                                <StackPanel><TextBlock Text="{Binding Strings[home.loadedModules]}" Style="{StaticResource SummaryLabelStyle}"/><TextBlock Margin="0,7,0,0" Text="{Binding LoadedModuleCount}" Style="{StaticResource SummaryNumberStyle}" Foreground="#2563EB"/></StackPanel>
                            </Border>
                            <Border Margin="9,9,0,0" Padding="20" Height="105" Style="{StaticResource SummaryCardStyle}">
                                <StackPanel><TextBlock Text="{Binding Strings[summary.failed]}" Style="{StaticResource SummaryLabelStyle}"/><TextBlock Margin="0,7,0,0" Text="{Binding FailedModuleCount}" Style="{StaticResource SummaryNumberStyle}" Foreground="#EA580C"/></StackPanel>
                            </Border>
                        </UniformGrid>

                        <Border Margin="0,18,0,0" Padding="22" Style="{StaticResource LiquidGlassPanelStyle}"
                                Effect="{StaticResource SoftPanelShadow}">
                            <StackPanel>
                                <TextBlock Text="{Binding Strings[home.recentModules]}" FontSize="16"
                                           FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                                <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding Modules}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="34" Height="34" Padding="6" CornerRadius="9" Background="#EAF2FF">
                                                    <Grid>
                                                        <svgc:SvgViewbox Visibility="{Binding HasIcon, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                         Source="{Binding IconPath, Converter={StaticResource ModuleIconSourceConverter}}"/>
                                                        <TextBlock Text="&#xE71D;" FontFamily="Segoe Fluent Icons"
                                                                   Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                                <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                                                    <TextBlock Margin="0,3,0,0" Text="{Binding DisplayDescription}" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <Border Grid.Column="2" VerticalAlignment="Center" Style="{StaticResource StateBadgeStyle}">
                                                    <TextBlock Text="{Binding DisplayRuntimeState}" FontSize="11" Foreground="#1D4ED8"/>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Grid Margin="0,18,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Height="72" Margin="0,0,9,0"
                                    Command="{Binding SelectNavigationCommand}" CommandParameter="Modules"
                                    Style="{StaticResource SecondaryActionButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE71D;" Style="{StaticResource CompactFluentIconStyle}"/>
                                    <TextBlock Text="{Binding Strings[home.browseModules]}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="1" Height="72" Margin="9,0,0,0"
                                    Command="{Binding RefreshModulesCommand}"
                                    Style="{StaticResource SecondaryActionButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE72C;" Style="{StaticResource CompactFluentIconStyle}"/>
                                    <TextBlock Text="{Binding Strings[modules.refresh]}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Grid Grid.Row="2" Grid.RowSpan="2"
                  Style="{StaticResource PageTransitionStyle}"
                  Visibility="{Binding IsRunningSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Border MaxWidth="600" Margin="24" HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource EmptyStateCardStyle}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RunningModules.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <Border Style="{StaticResource EmptyStateIconStyle}">
                                <TextBlock Text="&#xE768;" FontFamily="Segoe Fluent Icons" FontSize="27"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Margin="0,18,0,0" Text="{Binding Strings[empty.running.title]}"
                                       FontSize="21" FontWeight="SemiBold" TextAlignment="Center"
                                       Foreground="{StaticResource PrimaryTextBrush}" TextWrapping="Wrap"/>
                            <TextBlock Margin="0,8,0,16" Text="{Binding Strings[empty.running.description]}"
                                       TextAlignment="Center" TextWrapping="Wrap"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                            <Button HorizontalAlignment="Center" Command="{Binding SelectNavigationCommand}"
                                    CommandParameter="Modules"
                                    AutomationProperties.Name="{Binding Strings[empty.running.goToModules]}"
                                    Style="{StaticResource PrimaryActionButtonStyle}">
                                <TextBlock Text="{Binding Strings[empty.running.goToModules]}"/>
                            </Button>
                        </StackPanel>
                    </Border>
                    <ItemsControl ItemsSource="{Binding RunningModules}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RunningModules.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ModuleCardCompactStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource ModuleIconContainerStyle}">
                                            <Grid>
                                            <svgc:SvgViewbox
                                                Style="{StaticResource ModuleIconStyle}"
                                                Visibility="{Binding HasIcon, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                Source="{Binding IconPath, Converter={StaticResource ModuleIconSourceConverter}}"/>
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock"
                                                           BasedOn="{StaticResource DefaultModuleFluentIconStyle}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasIcon}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            </Grid>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}" FontSize="18" FontWeight="SemiBold"/>
                                            <TextBlock Margin="0,5,0,0" Text="{Binding DisplayRuntimeState}" Foreground="{StaticResource AccentBrush}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                            <Button Command="{Binding DataContext.OpenModuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Id}" IsEnabled="{Binding CanOpen}"
                                                    Style="{StaticResource PrimaryActionButtonStyle}" Content="{Binding DataContext.Strings[common.open], RelativeSource={RelativeSource AncestorType=Window}}"/>
                                            <Button Command="{Binding DataContext.DeactivateModuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Id}" IsEnabled="{Binding CanDeactivate}"
                                                    Style="{StaticResource SecondaryActionButtonStyle}" Content="{Binding DataContext.Strings[common.deactivate], RelativeSource={RelativeSource AncestorType=Window}}"/>
                                            <Button Command="{Binding DataContext.UnloadModuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Id}" IsEnabled="{Binding CanUnload}"
                                                    Style="{StaticResource DangerActionButtonStyle}" Content="{Binding DataContext.Strings[common.unload], RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Grid>

            <Grid Grid.Row="2" Grid.RowSpan="2"
                  Style="{StaticResource PageTransitionStyle}"
                  Visibility="{Binding IsSettingsSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ScrollViewer behaviors:SmoothScrollBehavior.IsEnabled="True"
                              VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Border MaxWidth="720" Margin="20" Padding="36" HorizontalAlignment="Center"
                        VerticalAlignment="Center" Background="White"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                        Style="{StaticResource LiquidGlassPanelStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding Strings[settings.title]}" FontSize="26" FontWeight="SemiBold"/>
                        <TextBlock Margin="0,8,0,24" Text="{Binding Strings[settings.subtitle]}"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                        <TextBlock Text="{Binding Strings[settings.language]}"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Margin="0,5,0,12"
                                   Text="{Binding Strings[settings.languageDescription]}"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                        <ComboBox Width="280"
                                  HorizontalAlignment="Left"
                                  Padding="10,7"
                                  ItemsSource="{Binding LanguageOptions}"
                                  DisplayMemberPath="DisplayText"
                                  SelectedValuePath="Code"
                                  SelectedValue="{Binding SelectedLanguageCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <Border Margin="0,24,0,0" Height="1" Background="#E2E8F0"/>
                        <TextBlock Margin="0,20,0,0" Text="{Binding Strings[closeBehavior.title]}"
                                   FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Margin="0,8,0,7" Text="{Binding Strings[closeBehavior.whenClosing]}"/>
                        <ComboBox Width="280" HorizontalAlignment="Left"
                                  SelectedValuePath="Tag"
                                  SelectedValue="{Binding SelectedMainWindowCloseBehavior, Mode=TwoWay}">
                            <ComboBox.Style><Style TargetType="ComboBox"><Style.Triggers><DataTrigger Binding="{Binding IsCloseBehaviorBusy}" Value="True"><Setter Property="IsEnabled" Value="False"/></DataTrigger></Style.Triggers></Style></ComboBox.Style>
                            <ComboBoxItem Tag="{x:Static settings:MainWindowCloseBehavior.MinimizeToNotificationArea}" Content="{Binding DataContext.Strings[closeBehavior.minimize], RelativeSource={RelativeSource AncestorType=Window}}"/>
                            <ComboBoxItem Tag="{x:Static settings:MainWindowCloseBehavior.ExitApplication}" Content="{Binding DataContext.Strings[closeBehavior.exit], RelativeSource={RelativeSource AncestorType=Window}}"/>
                            <ComboBoxItem Tag="{x:Static settings:MainWindowCloseBehavior.Ask}" Content="{Binding DataContext.Strings[closeBehavior.ask], RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </ComboBox>
                        <TextBlock Margin="0,8,0,0" Text="{Binding CloseBehaviorMessage}" TextWrapping="Wrap" Foreground="{StaticResource SecondaryTextBrush}"/>
                        <Border Margin="0,24,0,0" Height="1" Background="#E2E8F0"/>
                        <TextBlock Margin="0,20,0,0" Text="{Binding Strings[startup.settingsTitle]}"
                                   FontSize="16" FontWeight="SemiBold"/>
                        <CheckBox Margin="0,12,0,0"
                                  Content="{Binding Strings[startup.launchAtLogin]}"
                                  ToolTip="{Binding Strings[startup.launchAtLoginDescription]}"
                                  IsChecked="{Binding LaunchAtLogin, Mode=TwoWay}"
                                  IsEnabled="{Binding CanConfigureWindowsStartup}"
                                  Command="{Binding ApplyLaunchAtLoginCommand}">
                            <CheckBox.Style>
                                <Style TargetType="CheckBox">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStartupSettingsBusy}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </CheckBox.Style>
                        </CheckBox>
                        <TextBlock Margin="0,16,0,7" Text="{Binding Strings[startup.presentation]}"/>
                        <ComboBox Width="280" HorizontalAlignment="Left"
                                  SelectedValuePath="Tag"
                                  SelectedValue="{Binding SelectedStartupPresentationMode, Mode=TwoWay}">
                            <ComboBoxItem Tag="{x:Static settings:StartupPresentationMode.FloatingBadge}" Content="{Binding DataContext.Strings[startup.presentationFloating], RelativeSource={RelativeSource AncestorType=Window}}"/>
                            <ComboBoxItem Tag="{x:Static settings:StartupPresentationMode.Minimized}" Content="{Binding DataContext.Strings[startup.presentationMinimized], RelativeSource={RelativeSource AncestorType=Window}}"/>
                            <ComboBoxItem Tag="{x:Static settings:StartupPresentationMode.MainWindow}" Content="{Binding DataContext.Strings[startup.presentationMain], RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </ComboBox>
                        <TextBlock Margin="0,8,0,0" Text="{Binding StartupSettingsMessage}"
                                   TextWrapping="Wrap" Foreground="{StaticResource SecondaryTextBrush}"/>
                        <TextBlock Margin="0,16,0,0"
                                   Text="{Binding StartupAuthorizationSummary}"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                        <TextBlock Margin="0,4,0,0"
                                   Text="{Binding MissingStartupAuthorizationSummary}"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                        <Button Margin="0,10,0,0" HorizontalAlignment="Left"
                                Content="{Binding Strings[startup.clearMissing]}"
                                Command="{Binding ClearMissingStartupAuthorizationsCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding MissingStartupAuthorizationCount}" Value="0">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Border Margin="0,24,0,0" Height="1" Background="#E2E8F0"/>
                        <Border Margin="0,20,0,0" Padding="18"
                                Style="{StaticResource LiquidGlassPanelStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <svgc:SvgViewbox Width="56" Height="56"
                                                 Source="pack://application:,,,/QingToolbox.Shell;component/Assets/Branding/QingToolbox.Mark.svg"/>
                                <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                    <WrapPanel>
                                        <TextBlock Text="{Binding Strings[settings.about.product]}"
                                                   FontSize="18" FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                                        <Border Margin="10,0,0,0" Padding="9,3"
                                                Background="{StaticResource PrimaryAccentSoftBrush}"
                                                CornerRadius="9">
                                            <TextBlock Text="{Binding Strings[settings.about.preview]}"
                                                       FontSize="11" Foreground="{StaticResource AccentBrush}"/>
                                        </Border>
                                    </WrapPanel>
                                    <TextBlock Margin="0,5,0,0" Text="{Binding VersionDisplay}"
                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                    <TextBlock Margin="0,7,0,0"
                                               Text="{Binding Strings[settings.about.description]}"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
                </ScrollViewer>
            </Grid>
        </Grid>
        </Grid>
    </Grid>
</Window>
