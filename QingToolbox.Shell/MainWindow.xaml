<Window x:Class="QingToolbox.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}" Height="640" Width="1040" MinHeight="480" MinWidth="760"
        WindowStartupLocation="CenterScreen" Background="#F5F7FA">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Background="#172033">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock Text="QingToolbox" Foreground="White" FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock Text="模块化 Windows 工具箱" Foreground="#9EABC2" Margin="0,6,0,0"/>
                </StackPanel>
                <Button Grid.Row="1" Content="模块" Height="42" Margin="0,32,0,0"
                        VerticalAlignment="Top" HorizontalContentAlignment="Left" Padding="14,0"
                        Background="#27344F" Foreground="White" BorderThickness="0"/>
                <TextBlock Grid.Row="2" Text="轻量 · 按需加载" Foreground="#78869F"/>
            </Grid>
        </Border>
        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="QingToolbox" FontSize="34" FontWeight="SemiBold"
                       Foreground="#172033" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding Status}" Margin="0,12,0,0" FontSize="16" Foreground="#647087"/>
            <Border Margin="0,32,0,0" Padding="28,20" Background="White" CornerRadius="10">
                <TextBlock Text="模块尚未加载" Foreground="#647087"/>
            </Border>
        </StackPanel>
    </Grid>
</Window>
