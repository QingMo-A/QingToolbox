<Window x:Class="QingToolbox.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        Title="{Binding Title}"
        Width="1180"
        Height="760"
        MinWidth="900"
        MinHeight="580"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ShellBackgroundGradientBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border x:Name="Sidebar"
                Grid.Column="0"
                Width="72"
                Padding="12,16,12,20"
                ClipToBounds="True"
                Background="{StaticResource SidebarBackgroundBrush}"
                MouseEnter="OnSidebarMouseEnter"
                MouseLeave="OnSidebarMouseLeave">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Margin="8,0,8,22" Height="36">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="30"
                            Height="30"
                            Background="#2563EB"
                            CornerRadius="8">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="Q"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                    </Border>
                    <TextBlock Grid.Column="1"
                               Text="Qing Toolbox"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Style="{StaticResource SidebarLabelStyle}"/>
                </Grid>

                <Button Grid.Row="1"
                        AutomationProperties.Name="Home"
                        Command="{Binding SelectNavigationCommand}"
                        CommandParameter="Home">
                    <Button.Style>
                        <Style BasedOn="{StaticResource SidebarButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedNavigationKey}" Value="Home">
                                    <Setter Property="Tag" Value="Selected"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource SidebarIconContainerStyle}">
                            <svgc:SvgViewbox
                                Style="{StaticResource ShellSvgIconStyle}"
                                Source="/QingToolbox.Shell;component/Assets/Icons/Nieobie/home.svg"/>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="Home"
                                   Style="{StaticResource SidebarLabelStyle}"/>
                    </Grid>
                </Button>

                <Button Grid.Row="2"
                        AutomationProperties.Name="Modules"
                        Command="{Binding SelectNavigationCommand}"
                        CommandParameter="Modules">
                    <Button.Style>
                        <Style BasedOn="{StaticResource SidebarButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedNavigationKey}" Value="Modules">
                                    <Setter Property="Tag" Value="Selected"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource SidebarIconContainerStyle}">
                            <svgc:SvgViewbox
                                Style="{StaticResource ShellSvgIconStyle}"
                                Source="/QingToolbox.Shell;component/Assets/Icons/Nieobie/modules.svg"/>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="Modules"
                                   Style="{StaticResource SidebarLabelStyle}"/>
                    </Grid>
                </Button>

                <Button Grid.Row="3"
                        AutomationProperties.Name="Running"
                        Command="{Binding SelectNavigationCommand}"
                        CommandParameter="Running">
                    <Button.Style>
                        <Style BasedOn="{StaticResource SidebarButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedNavigationKey}" Value="Running">
                                    <Setter Property="Tag" Value="Selected"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource SidebarIconContainerStyle}">
                            <svgc:SvgViewbox
                                Style="{StaticResource ShellSvgIconStyle}"
                                Source="/QingToolbox.Shell;component/Assets/Icons/Nieobie/running.svg"/>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="Running"
                                   Style="{StaticResource SidebarLabelStyle}"/>
                    </Grid>
                </Button>

                <Button Grid.Row="5"
                        Click="OnPinSidebarClick"
                        ToolTip="Pin or unpin the sidebar"
                        Style="{StaticResource SidebarButtonStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource SidebarIconContainerStyle}">
                            <svgc:SvgViewbox
                                Style="{StaticResource ShellSvgIconStyle}"
                                Source="/QingToolbox.Shell;component/Assets/Icons/Nieobie/pin.svg"/>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding PinLabel}"
                                   Style="{StaticResource SidebarLabelStyle}"/>
                    </Grid>
                </Button>

                <Button Grid.Row="6"
                        AutomationProperties.Name="Settings"
                        Command="{Binding SelectNavigationCommand}"
                        CommandParameter="Settings">
                    <Button.Style>
                        <Style BasedOn="{StaticResource SidebarButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedNavigationKey}" Value="Settings">
                                    <Setter Property="Tag" Value="Selected"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource SidebarIconContainerStyle}">
                            <svgc:SvgViewbox
                                Style="{StaticResource ShellSvgIconStyle}"
                                Source="/QingToolbox.Shell;component/Assets/Icons/Nieobie/settings.svg"/>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="Settings"
                                   Style="{StaticResource SidebarLabelStyle}"/>
                    </Grid>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="34,28,34,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding PageTitle}"
                               FontSize="30"
                               FontWeight="SemiBold"
                               Foreground="#172033"/>
                    <TextBlock Margin="0,7,0,0"
                               Text="{Binding PageSubtitle}"
                               FontSize="15"
                               Foreground="#64748B"/>
                </StackPanel>
                <Button Grid.Column="1"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="Refresh Modules"
                        Command="{Binding RefreshModulesCommand}"
                        Style="{StaticResource RefreshButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <svgc:SvgViewbox
                            Margin="0,0,8,0"
                            Style="{StaticResource CompactSvgIconStyle}"
                            Source="/QingToolbox.Shell;component/Assets/Icons/Nieobie/refresh.svg"/>
                        <TextBlock VerticalAlignment="Center" Text="Refresh Modules"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,20,0,16"
                    Style="{StaticResource StatusMessageStyle}">
                <TextBlock Text="{Binding StatusMessage}" Foreground="#475569"/>
            </Border>

            <Grid Grid.Row="2" Margin="0,0,0,20"
                  Style="{StaticResource PageTransitionStyle}"
                  Visibility="{Binding IsModulesSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="TOTAL" Style="{StaticResource SummaryLabelStyle}"/>
                        <TextBlock Text="{Binding TotalModuleCount}"
                                   Style="{StaticResource SummaryNumberStyle}"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="VALID" Style="{StaticResource SummaryLabelStyle}"/>
                        <TextBlock Text="{Binding ValidModuleCount}"
                                   Style="{StaticResource SummaryNumberStyle}"
                                   Foreground="#15803D"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="FAILED" Style="{StaticResource SummaryLabelStyle}"/>
                        <TextBlock Text="{Binding FailedModuleCount}"
                                   Style="{StaticResource SummaryNumberStyle}"
                                   Foreground="#B45309"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="NOT LOADED" Style="{StaticResource SummaryLabelStyle}"/>
                        <TextBlock Text="{Binding NotLoadedModuleCount}"
                                   Style="{StaticResource SummaryNumberStyle}"
                                   Foreground="#2563EB"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="4" Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="LOADED" Style="{StaticResource SummaryLabelStyle}"/>
                        <TextBlock Text="{Binding LoadedModuleCount}"
                                   Style="{StaticResource SummaryNumberStyle}"
                                   Foreground="#0369A1"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="5" Style="{StaticResource SummaryCardStyle}" Margin="0">
                    <StackPanel>
                        <TextBlock Text="RUNNING" Style="{StaticResource SummaryLabelStyle}"/>
                        <TextBlock Text="{Binding RunningModuleCount}"
                                   Style="{StaticResource SummaryNumberStyle}"
                                   Foreground="#15803D"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="3"
                  Style="{StaticResource PageTransitionStyle}"
                  Visibility="{Binding IsModulesSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="0"/>
                </Grid.ColumnDefinitions>
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Text="No modules discovered. Add module packages to the runtime Modules directory."
                           Foreground="#64748B"
                           TextAlignment="Center"
                           Grid.Column="0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Modules.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Modules}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Modules.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ModuleCardCompactStyle}">
                                    <StackPanel>
                                        <Expander Header="Details"
                                                  IsExpanded="False"
                                                  Style="{StaticResource ModuleDetailsExpanderStyle}">
                                        <StackPanel Margin="0,10,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    Style="{StaticResource ModuleIconContainerStyle}">
                                                <svgc:SvgViewbox
                                                    Style="{StaticResource ModuleIconStyle}"
                                                    Source="{Binding IconPath, Converter={StaticResource ModuleIconSourceConverter}}"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="19"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource PrimaryTextBrush}"/>
                                                <TextBlock Margin="10,4,0,0"
                                                           Text="{Binding Version, StringFormat=v{0}}"
                                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                                            </StackPanel>
                                            <Border Grid.Column="2"
                                                    Style="{StaticResource StateBadgeStyle}">
                                                <TextBlock Text="{Binding RuntimeState}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#1D4ED8"/>
                                            </Border>
                                        </Grid>

                                        <TextBlock Margin="0,10,0,16"
                                                   Text="{Binding Description}"
                                                   TextWrapping="Wrap"
                                                   Foreground="#475569"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,16,12">
                                                <TextBlock Text="Runtime" Style="{StaticResource InfoLabelStyle}"/>
                                                <TextBlock Text="{Binding RuntimeType}" Style="{StaticResource InfoValueStyle}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="0,0,16,12">
                                                <TextBlock Text="Load mode" Style="{StaticResource InfoLabelStyle}"/>
                                                <TextBlock Text="{Binding LoadMode}" Style="{StaticResource InfoValueStyle}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Margin="0,0,0,12">
                                                <TextBlock Text="Author" Style="{StaticResource InfoLabelStyle}"/>
                                                <TextBlock Text="{Binding Author}" Style="{StaticResource InfoValueStyle}"/>
                                            </StackPanel>
                                        </Grid>

                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="Permissions" Style="{StaticResource InfoLabelStyle}"/>
                                            <TextBlock Text="{Binding PermissionsText}" Style="{StaticResource InfoValueStyle}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="Entry" Style="{StaticResource InfoLabelStyle}"/>
                                            <TextBlock Text="{Binding Entry}" Style="{StaticResource InfoValueStyle}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="Module directory" Style="{StaticResource InfoLabelStyle}"/>
                                            <TextBlock Text="{Binding ModuleDirectory}" Style="{StaticResource InfoValueStyle}"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Manifest" Style="{StaticResource InfoLabelStyle}"/>
                                            <TextBlock Text="{Binding ManifestPath}" Style="{StaticResource InfoValueStyle}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,12,0,0">
                                            <TextBlock Text="Minimum host version" Style="{StaticResource InfoLabelStyle}"/>
                                            <TextBlock Text="{Binding MinimumHostVersion}" Style="{StaticResource InfoValueStyle}"/>
                                        </StackPanel>
                                        </StackPanel>
                                        </Expander>

                                        <Grid Margin="0,16,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Runtime State:"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                                            <TextBlock Grid.Column="1"
                                                       Margin="8,0,0,0"
                                                       Text="{Binding RuntimeState}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource AccentBrush}"/>
                                        </Grid>

                                        <WrapPanel Margin="0,14,0,0">
                                            <Button AutomationProperties.Name="Load"
                                                    Command="{Binding DataContext.LoadModuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Id}"
                                                    IsEnabled="{Binding CanLoad}"
                                                    Style="{StaticResource PrimaryActionButtonStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                    <svgc:SvgViewbox Margin="0,0,6,0"
                                                                      Style="{StaticResource CompactSvgIconStyle}"
                                                                      Source="/QingToolbox.Shell;component/Assets/Icons/Nieobie/load.svg"/>
                                                    <TextBlock VerticalAlignment="Center" Text="Load"/>
                                                </StackPanel>
                                            </Button>
                                            <Button AutomationProperties.Name="Activate"
                                                    Command="{Binding DataContext.ActivateModuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Id}"
                                                    IsEnabled="{Binding CanActivate}"
                                                    Style="{StaticResource SecondaryActionButtonStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                    <svgc:SvgViewbox Margin="0,0,6,0"
                                                                      Style="{StaticResource CompactSvgIconStyle}"
                                                                      Source="/QingToolbox.Shell;component/Assets/Icons/Nieobie/activate.svg"/>
                                                    <TextBlock VerticalAlignment="Center" Text="Activate"/>
                                                </StackPanel>
                                            </Button>
                                            <Button AutomationProperties.Name="Deactivate"
                                                    Command="{Binding DataContext.DeactivateModuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Id}"
                                                    IsEnabled="{Binding CanDeactivate}"
                                                    Style="{StaticResource SecondaryActionButtonStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                    <svgc:SvgViewbox Margin="0,0,6,0"
                                                                      Style="{StaticResource CompactSvgIconStyle}"
                                                                      Source="/QingToolbox.Shell;component/Assets/Icons/Nieobie/deactivate.svg"/>
                                                    <TextBlock VerticalAlignment="Center" Text="Deactivate"/>
                                                </StackPanel>
                                            </Button>
                                            <Button AutomationProperties.Name="Unload"
                                                    Command="{Binding DataContext.UnloadModuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Id}"
                                                    IsEnabled="{Binding CanUnload}"
                                                    Style="{StaticResource DangerActionButtonStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                    <svgc:SvgViewbox Margin="0,0,6,0"
                                                                      Style="{StaticResource CompactSvgIconStyle}"
                                                                      Source="/QingToolbox.Shell;component/Assets/Icons/Nieobie/unload.svg"/>
                                                    <TextBlock VerticalAlignment="Center" Text="Unload"/>
                                                </StackPanel>
                                            </Button>
                                            <Button AutomationProperties.Name="Open"
                                                    Command="{Binding DataContext.OpenModuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Id}"
                                                    IsEnabled="{Binding CanOpen}"
                                                    Style="{StaticResource PrimaryActionButtonStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                    <svgc:SvgViewbox Margin="0,0,6,0"
                                                                      Style="{StaticResource CompactSvgIconStyle}"
                                                                      Source="/QingToolbox.Shell;component/Assets/Icons/Nieobie/open.svg"/>
                                                    <TextBlock VerticalAlignment="Center" Text="Open"/>
                                                </StackPanel>
                                            </Button>
                                        </WrapPanel>

                                        <Border>
                                            <Border.Style>
                                                <Style BasedOn="{StaticResource RuntimeErrorPanelStyle}"
                                                       TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasRuntimeError}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <TextBlock Text="Runtime Error"
                                                           FontWeight="SemiBold"
                                                           Foreground="#991B1B"/>
                                                <TextBlock Margin="0,5,0,0"
                                                           Text="{Binding RuntimeError}"
                                                           TextWrapping="Wrap"
                                                           Foreground="#991B1B"/>
                                            </StackPanel>
                                        </Border>

                                        <Border>
                                            <Border.Style>
                                                <Style BasedOn="{StaticResource ErrorPanelStyle}" TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasErrors}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <TextBlock Text="{Binding ErrorSummary}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#9A3412"/>
                                                <ItemsControl Margin="0,6,0,0" ItemsSource="{Binding Errors}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Margin="0,2,0,0"
                                                                       Text="{Binding}"
                                                                       TextWrapping="Wrap"
                                                                       Foreground="#9A3412"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>

                                        <TextBlock Margin="0,12,0,0"
                                                   Text="{Binding ErrorSummary}"
                                                   Foreground="#15803D">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasErrors}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Column="1" Style="{StaticResource WorkspacePanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Padding="18,14"
                                BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <DockPanel>
                                <Button DockPanel.Dock="Right"
                                        AutomationProperties.Name="Close"
                                        IsEnabled="False">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource CloseViewButtonStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <svgc:SvgViewbox Margin="0,0,6,0"
                                                          Style="{StaticResource CompactSvgIconStyle}"
                                                          Source="/QingToolbox.Shell;component/Assets/Icons/Nieobie/close.svg"/>
                                        <TextBlock VerticalAlignment="Center" Text="Close"/>
                                    </StackPanel>
                                </Button>
                                <StackPanel>
                                    <TextBlock Text="Workspace" Style="{StaticResource ModuleViewHeaderStyle}"/>
                                    <TextBlock Margin="0,4,0,0"
                                               Text="Open a loaded module to start working."
                                               FontSize="12"
                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <Grid Grid.Row="1">
                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel" BasedOn="{StaticResource WorkspaceEmptyStateStyle}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </Style>
                                </StackPanel.Style>
                                <Border Width="76" Height="76" Margin="0,0,0,20"
                                        Background="#EFF6FF" CornerRadius="22">
                                    <svgc:SvgViewbox Width="38" Height="38"
                                                      Source="/QingToolbox.Shell;component/Assets/Icons/Nieobie/modules.svg"/>
                                </Border>
                                <TextBlock Text="Select a loaded module and click Open."
                                           FontSize="18" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           TextAlignment="Center"/>
                                <TextBlock Margin="0,9,0,0"
                                           Text="Modules are loaded manually and unloaded when no longer needed."
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           TextAlignment="Center" TextWrapping="Wrap"/>
                            </StackPanel>

                            <ContentControl Margin="1">
                                <ContentControl.Style>
                                    <Style TargetType="ContentControl">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </Style>
                                </ContentControl.Style>
                            </ContentControl>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="2" Grid.RowSpan="2"
                  Style="{StaticResource PageTransitionStyle}"
                  Visibility="{Binding IsHomeSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border MaxWidth="860" Padding="42" HorizontalAlignment="Center"
                        VerticalAlignment="Center" Background="White"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                        Style="{StaticResource LiquidGlassPanelStyle}">
                    <StackPanel>
                        <TextBlock Text="Welcome to Qing Toolbox" FontSize="30"
                                   FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Margin="0,10,0,26"
                                   Text="A modular Windows toolbox where tools are loaded only when needed."
                                   FontSize="15" Foreground="{StaticResource SecondaryTextBrush}"/>
                        <Grid Margin="0,0,0,26">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource SummaryCardStyle}">
                                <StackPanel><TextBlock Text="{Binding TotalModuleCount}" Style="{StaticResource SummaryNumberStyle}"/><TextBlock Text="INSTALLED MODULES" Style="{StaticResource SummaryLabelStyle}"/></StackPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource SummaryCardStyle}">
                                <StackPanel><TextBlock Text="{Binding LoadedModuleCount}" Style="{StaticResource SummaryNumberStyle}"/><TextBlock Text="LOADED MODULES" Style="{StaticResource SummaryLabelStyle}"/></StackPanel>
                            </Border>
                            <Border Grid.Column="2" Margin="0" Style="{StaticResource SummaryCardStyle}">
                                <StackPanel><TextBlock Text="{Binding RunningModuleCount}" Style="{StaticResource SummaryNumberStyle}"/><TextBlock Text="RUNNING MODULES" Style="{StaticResource SummaryLabelStyle}"/></StackPanel>
                            </Border>
                        </Grid>
                        <Button Width="150" HorizontalAlignment="Left"
                                Command="{Binding SelectNavigationCommand}"
                                CommandParameter="Modules"
                                Style="{StaticResource PrimaryActionButtonStyle}">
                            <TextBlock Text="Browse Modules"/>
                        </Button>
                        <TextBlock Margin="0,18,0,0"
                                   Text="Modules are discovered from the runtime Modules folder and loaded manually."
                                   FontSize="12" Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="2" Grid.RowSpan="2"
                  Style="{StaticResource PageTransitionStyle}"
                  Visibility="{Binding IsRunningSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                               Text="No modules are currently loaded."
                               Foreground="{StaticResource SecondaryTextBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RunningModules.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding RunningModules}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ModuleCardCompactStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="SemiBold"/>
                                            <TextBlock Margin="0,5,0,0" Text="{Binding RuntimeState}" Foreground="{StaticResource AccentBrush}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Command="{Binding DataContext.OpenModuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Id}" IsEnabled="{Binding CanOpen}"
                                                    Style="{StaticResource PrimaryActionButtonStyle}" Content="Open"/>
                                            <Button Command="{Binding DataContext.DeactivateModuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Id}" IsEnabled="{Binding CanDeactivate}"
                                                    Style="{StaticResource SecondaryActionButtonStyle}" Content="Deactivate"/>
                                            <Button Command="{Binding DataContext.UnloadModuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Id}" IsEnabled="{Binding CanUnload}"
                                                    Style="{StaticResource DangerActionButtonStyle}" Content="Unload"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Grid>

            <Grid Grid.Row="2" Grid.RowSpan="2"
                  Style="{StaticResource PageTransitionStyle}"
                  Visibility="{Binding IsSettingsSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border MaxWidth="720" Padding="36" HorizontalAlignment="Center"
                        VerticalAlignment="Center" Background="White"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                        Style="{StaticResource LiquidGlassPanelStyle}">
                    <StackPanel>
                        <TextBlock Text="Settings" FontSize="26" FontWeight="SemiBold"/>
                        <TextBlock Margin="0,8,0,24" Text="Qing Toolbox settings will appear here."
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                        <TextBlock Text="Theme" Style="{StaticResource InfoLabelStyle}"/>
                        <TextBox Margin="0,4,0,14" Text="System default" IsEnabled="False"/>
                        <TextBlock Text="Module directory" Style="{StaticResource InfoLabelStyle}"/>
                        <TextBox Margin="0,4,0,14" Text="Runtime Modules folder" IsEnabled="False"/>
                        <CheckBox Content="Load modules at startup" IsEnabled="False"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
