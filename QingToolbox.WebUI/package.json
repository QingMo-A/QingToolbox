{
  "name": "qingtoolbox-webui",
  "private": true,
  "version": "0.2.0-alpha",
  "type": "module",
  "scripts": {
    "dev": "vite --mode mock",
    "dev:webview": "vite",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "build": "npm run typecheck && vite build && node tools/assets.mjs generate && npm run verify-assets",
    "verify-assets": "node tools/assets.mjs verify"
  },
  "dependencies": {
    "pinia": "^3.0.3",
    "vue": "^3.5.22",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^27.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.10",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.1.1"
  }
}
