<UserControl x:Class="QingToolbox.Modules.PowerGuard.Views.PowerGuardView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
 <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="28" MaxWidth="900">
  <TextBlock x:Name="TitleText" FontSize="28" FontWeight="Bold" Foreground="#102A56"/><TextBlock x:Name="SubtitleText" Margin="0,6,0,20" Foreground="#60708A" TextWrapping="Wrap"/>
  <UniformGrid Columns="3" Margin="0,0,0,18">
   <Border Margin="0,0,10,0" Padding="16" CornerRadius="14" Background="#EEF5FF"><StackPanel><TextBlock x:Name="GuardLabel" Foreground="#60708A"/><TextBlock Text="{Binding GuardStatusText}" FontSize="20" FontWeight="SemiBold"/><TextBlock Text="{Binding NetworkStatusText}" Foreground="#52647E"/></StackPanel></Border>
   <Border Margin="0,0,10,0" Padding="16" CornerRadius="14" Background="#F3F8FF"><StackPanel><TextBlock x:Name="StateLabel" Foreground="#60708A"/><TextBlock Text="{Binding StateText}" FontSize="20" FontWeight="SemiBold"/><TextBlock Text="{Binding LastOnlineText}" Foreground="#52647E"/></StackPanel></Border>
   <Border Padding="16" CornerRadius="14" Background="#F6F9FD"><StackPanel><TextBlock x:Name="CountdownLabel" Foreground="#60708A"/><TextBlock Text="{Binding Countdown}" Visibility="{Binding CountdownVisibility}" FontSize="20" FontWeight="SemiBold"/><TextBlock Text="{Binding LastProbeText}" Foreground="#52647E"/><TextBlock Text="{Binding LastSuccessfulProbeText}" Foreground="#52647E"/><TextBlock Text="{Binding ConsecutiveFailuresText}" Foreground="#52647E"/></StackPanel></Border>
  </UniformGrid>
  <GroupBox x:Name="SettingsGroup" Padding="16"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
   <CheckBox x:Name="GuardCheck" Grid.ColumnSpan="2" IsChecked="{Binding EditableSettings.GuardEnabled}" Margin="0,0,0,12"/>
   <StackPanel Grid.Row="1" Margin="0,0,10,10"><TextBlock x:Name="GraceLabel"/><TextBox Text="{Binding EditableSettings.StartupGraceSeconds,ValidatesOnExceptions=True,NotifyOnValidationError=True}"/><TextBlock Text="0–600" Foreground="#718096" FontSize="11"/></StackPanel>
   <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,10"><TextBlock x:Name="OfflineLabel"/><TextBox Text="{Binding EditableSettings.OfflineConfirmationSeconds,ValidatesOnExceptions=True,NotifyOnValidationError=True}"/><TextBlock Text="15–300" Foreground="#718096" FontSize="11"/></StackPanel>
   <StackPanel Grid.Row="2" Margin="0,0,10,0"><TextBlock x:Name="ShutdownLabel"/><TextBox Text="{Binding EditableSettings.ShutdownCountdownSeconds,ValidatesOnExceptions=True,NotifyOnValidationError=True}"/><TextBlock Text="60–3600" Foreground="#718096" FontSize="11"/></StackPanel>
   <StackPanel Grid.Row="2" Grid.Column="1"><TextBlock x:Name="RecoveryLabel"/><TextBox Text="{Binding EditableSettings.RecoveryConfirmationSeconds,ValidatesOnExceptions=True,NotifyOnValidationError=True}"/><TextBlock Text="5–120" Foreground="#718096" FontSize="11"/></StackPanel>
  </Grid></GroupBox>
  <WrapPanel Margin="0,16,0,0"><Button x:Name="SaveButton" IsEnabled="{Binding CanSave}" Padding="16,9" Margin="0,0,8,8" Click="Save_Click"/><Button x:Name="ProbeButton" IsEnabled="{Binding CanProbe}" Padding="16,9" Margin="0,0,8,8" Click="Probe_Click"/><Button x:Name="TestButton" IsEnabled="{Binding CanTest}" Padding="16,9" Margin="0,0,8,8" Click="Test_Click"/><Button x:Name="CancelButton" IsEnabled="{Binding CanSuppress}" Padding="16,9" Margin="0,0,8,8" Click="Cancel_Click"/><Button x:Name="RearmButton" IsEnabled="{Binding CanRearm}" Padding="16,9" Margin="0,0,8,8" Click="Rearm_Click"/></WrapPanel>
  <TextBlock x:Name="StatusText" Margin="0,8,0,0" Foreground="#2563EB" TextWrapping="Wrap"/>
  <Border Margin="0,18,0,0" Padding="16" CornerRadius="14" Background="#F6F9FD"><TextBlock x:Name="NoticeText" TextWrapping="Wrap" Foreground="#52647E"/></Border>
  <GroupBox x:Name="RecentEventsGroup" Margin="0,18,0,0" Padding="10"><ListBox ItemsSource="{Binding RecentEvents}" MaxHeight="220" BorderThickness="0" Background="Transparent"/></GroupBox>
 </StackPanel></ScrollViewer>
</UserControl>
