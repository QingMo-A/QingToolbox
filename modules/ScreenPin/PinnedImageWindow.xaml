<Window x:Class="QingToolbox.Modules.ScreenPin.PinnedImageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="480" Height="320" MinWidth="180" MinHeight="120"
        WindowStyle="None" ResizeMode="CanResizeWithGrip"
        Topmost="True" ShowInTaskbar="False" Background="#111827">
    <Grid>
        <Image x:Name="PinnedImage" Stretch="Uniform"/>
        <Border VerticalAlignment="Top" Background="#CC111827" Padding="8,5"
                MouseLeftButtonDown="OnDrag">
            <DockPanel>
                <Button DockPanel.Dock="Right" Margin="8,0,0,0" Padding="8,2"
                        Click="OnClose" Content="Close"/>
                <CheckBox x:Name="TopmostToggle" IsChecked="True"
                          Checked="OnTopmostChanged" Unchecked="OnTopmostChanged"
                          Foreground="White" Content="Always on top"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
