<Window x:Class="QingToolbox.Modules.ScreenPin.PinnedImageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        MinWidth="120" MinHeight="80"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <Window.Resources>
        <CubicEase x:Key="OverlayEase" EasingMode="EaseInOut"/>

        <Style x:Key="OverlayIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#7A0F172A"/>
            <Setter Property="BorderBrush" Value="#55FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#B51D4ED8"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#80BFDBFE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#D91E40AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="ImageHost"
          Background="Transparent"
          MouseEnter="OnHostMouseEnter"
          MouseLeave="OnHostMouseLeave"
          MouseLeftButtonDown="OnImageHostMouseLeftButtonDown">
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem x:Name="TopmostMenuItem"
                          Header="取消置顶"
                          Click="OnToggleTopmost"/>
                <MenuItem x:Name="ResizeModeMenuItem"
                          Header="自由拉伸"
                          Click="OnToggleResizeMode"/>
                <MenuItem Header="复制"
                          Click="OnCopy"/>
                <Separator/>
                <MenuItem Header="关闭"
                          Click="OnClose"/>
            </ContextMenu>
        </Grid.ContextMenu>

        <Border x:Name="ImageFrame"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="0"
                CornerRadius="4"
                ClipToBounds="True">
            <Image x:Name="PinnedImage"
                   Stretch="Uniform"
                   SnapsToDevicePixels="True"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
        </Border>

        <Grid x:Name="OverlayControls"
              Margin="8"
              Opacity="0"
              IsHitTestVisible="False">
            <StackPanel HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Orientation="Horizontal">
                <Button x:Name="TopmostButton"
                        Style="{StaticResource OverlayIconButtonStyle}"
                        Content="LOCK"
                        ToolTip="取消置顶"
                        Click="OnToggleTopmost"/>
                <Button x:Name="ResizeModeButton"
                        Style="{StaticResource OverlayIconButtonStyle}"
                        Content="1:1"
                        ToolTip="等比例缩放"
                        Click="OnToggleResizeMode"/>
                <Button Style="{StaticResource OverlayIconButtonStyle}"
                        Content="COPY"
                        ToolTip="复制"
                        Click="OnCopy"/>
            </StackPanel>

            <Button HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0"
                    Width="30"
                    Style="{StaticResource OverlayIconButtonStyle}"
                    Content="×"
                    FontSize="18"
                    ToolTip="关闭"
                    Click="OnClose"/>
        </Grid>

        <Thumb x:Name="CornerResizeGrip"
               Width="18"
               Height="18"
               HorizontalAlignment="Right"
               VerticalAlignment="Bottom"
               Margin="0,0,1,1"
               Cursor="SizeNWSE"
               Opacity="0.52"
               DragDelta="OnResizeGripDragDelta">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Grid Background="Transparent">
                        <Path Stroke="#CCFFFFFF"
                              StrokeThickness="1.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Data="M 6 15 L 15 6 M 11 16 L 16 11"/>
                    </Grid>
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>
    </Grid>
</Window>
