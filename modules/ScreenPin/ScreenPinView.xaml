<UserControl x:Class="QingToolbox.Modules.ScreenPin.ScreenPinView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28">
        <StackPanel>
            <TextBlock FontSize="26" FontWeight="SemiBold" Text="Screen Pin"/>
            <TextBlock Margin="0,8,0,24" Foreground="#64748B"
                       Text="Capture a screen region and keep it on screen as a floating image."/>
            <WrapPanel>
                <Button Padding="18,10" Margin="0,0,10,0"
                        Click="OnCapture" Content="Capture Region"/>
                <Button Padding="18,10" Click="OnCloseAll" Content="Close All Pins"/>
            </WrapPanel>
            <TextBlock x:Name="CountText" Margin="0,22,0,0" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</UserControl>
