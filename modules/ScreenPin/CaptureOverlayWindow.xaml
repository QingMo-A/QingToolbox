<Window x:Class="QingToolbox.Modules.ScreenPin.CaptureOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="#66000000"
        ShowInTaskbar="False" Topmost="True" Cursor="Cross"
        KeyDown="OnKeyDown" MouseLeftButtonDown="OnMouseDown"
        MouseMove="OnMouseMove" MouseLeftButtonUp="OnMouseUp">
    <Canvas>
        <Rectangle x:Name="Selection" Stroke="#38BDF8" StrokeThickness="2"
                   Fill="#2238BDF8" Visibility="Collapsed"/>
        <TextBlock Canvas.Left="24" Canvas.Top="20" Foreground="White"
                   FontSize="16" Text="Drag to capture a region · Esc to cancel"/>
    </Canvas>
</Window>
