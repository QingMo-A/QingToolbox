<UserControl x:Class="QingToolbox.Modules.WindowTopmost.WindowTopmostView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F8FE">
    <UserControl.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#10264A"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#64748B"/>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#23446F"/>
            <Setter Property="BorderBrush" Value="#D6E2F3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="11">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#EDF4FF"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#AFC9F5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#DCEAFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.48"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="11">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.48"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#F7FAFF"/>
            <Setter Property="Foreground" Value="#60738F"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#E5EDF8"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="48"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F2F7FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E2EDFF"/>
                    <Setter Property="Foreground" Value="#153F88"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Padding="22" CornerRadius="18" BorderBrush="#D9E7FA" BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FFFFFF" Offset="0"/>
                    <GradientStop Color="#EAF3FF" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Width="52" Height="52" CornerRadius="15" Background="#2563EB">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontFamily="Segoe Fluent Icons" FontSize="25" Foreground="White"
                               Text="&#xE718;"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="16,1,0,0">
                    <TextBlock x:Name="TitleText" FontSize="25" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}" Text="Window Topmost"/>
                    <TextBlock x:Name="SubtitleText" Margin="0,5,0,0" Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap" Text="Choose a visible window and toggle always-on-top."/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <WrapPanel VerticalAlignment="Center">
                <Button x:Name="RefreshButton" Style="{StaticResource ActionButton}" Click="OnRefresh">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Margin="0,0,7,0" FontFamily="Segoe Fluent Icons" Text="&#xE72C;"/>
                        <TextBlock x:Name="RefreshButtonText" Text="Refresh"/>
                    </StackPanel>
                </Button>
                <Button x:Name="PickButton" Style="{StaticResource ActionButton}" Click="OnPick">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Margin="0,0,7,0" FontFamily="Segoe Fluent Icons" Text="&#xE7C8;"/>
                        <TextBlock x:Name="PickButtonText" Text="Pick Window"/>
                    </StackPanel>
                </Button>
            </WrapPanel>
            <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                <Button x:Name="RemoveTopmostButton" Style="{StaticResource ActionButton}" Click="OnRemoveTopmost">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Margin="0,0,7,0" FontFamily="Segoe Fluent Icons" Text="&#xE77A;"/>
                        <TextBlock x:Name="RemoveTopmostButtonText" Text="Remove Topmost"/>
                    </StackPanel>
                </Button>
                <Button x:Name="SetTopmostButton" Margin="0" Style="{StaticResource PrimaryButton}" Click="OnSetTopmost">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Margin="0,0,7,0" FontFamily="Segoe Fluent Icons" Text="&#xE840;"/>
                        <TextBlock x:Name="SetTopmostButtonText" Text="Set Topmost"/>
                    </StackPanel>
                </Button>
            </WrapPanel>
        </Grid>

        <Border Grid.Row="2" Background="White" BorderBrush="#DDE8F6" BorderThickness="1" CornerRadius="16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.08" Color="#31598F"/>
            </Border.Effect>
            <DataGrid x:Name="WindowGrid" AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single" SelectionUnit="FullRow" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EDF2F8"
                      BorderThickness="0" Background="Transparent" RowHeaderWidth="0">
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="TitleColumn" Header="Title" Binding="{Binding Title}" Width="*"/>
                    <DataGridTextColumn x:Name="ProcessColumn" Header="Process" Binding="{Binding ProcessName}" Width="170"/>
                    <DataGridTextColumn x:Name="HwndColumn" Header="HWND" Binding="{Binding HandleText}" Width="135"/>
                    <DataGridTextColumn x:Name="TopmostColumn" Header="Topmost" Binding="{Binding TopmostText}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="3" Margin="0,14,0,0" Padding="14,11" CornerRadius="11"
                Background="#EAF3FF" BorderBrush="#D2E3FC" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Margin="0,0,9,0" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons"
                           Foreground="{StaticResource AccentBrush}" Text="&#xE946;"/>
                <TextBlock x:Name="StatusText" VerticalAlignment="Center" TextWrapping="Wrap"
                           Foreground="#35577F"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
